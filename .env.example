# spicyninja.org environment variables
# Copy to .env and set your passphrase hash

# SHA-256 hash of your admin passphrase (PUBLIC_ prefix = exposed to client bundle, safe for hash)
# Generate: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('YOUR_PASSPHRASE').digest('hex'))"
PUBLIC_AUTH_PASSPHRASE_HASH=REPLACE_WITH_YOUR_HASH
