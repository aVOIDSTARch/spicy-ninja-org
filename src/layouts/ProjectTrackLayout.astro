---
/*
  ProjectTrackLayout.astro
  Renders a single project-track work page.

  Features:
  - Slide-away TOC (all 8 works listed, current highlighted)
  - Module color accent on current work
  - YouTube embed via youtubeId frontmatter
  - Spotify/Apple Music links
  - 4-layer visual structure: Pre-listening / Listen For / What It Teaches / Deep Read
  - Course notes panel slot (right slide-out, built later)
  - Zone: project-track / SceneDojo behind content
*/

import ZoneLayout from './ZoneLayout.astro'
import SceneDojo from '../components/scenes/SceneDojo.astro'
import { getCollection } from 'astro:content'

interface Props {
  work: {
    id: string
    data: {
      title: string
      composer: string
      year: string
      module: 1|2|3|4
      order: number
      recording?: string
      youtubeQuery: string
      youtubeId?: string
      youtubeId2?: string
      spotifyUrl?: string
      appleMusicUrl?: string
      listenFor: string[]
      teaches: string[]
      draft: boolean
    }
  }
}

const { work } = Astro.props

// Get all works for TOC, sorted by order
const allWorks = (await getCollection('project-track'))
  .filter(w => !w.data.draft)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))

// Module color accents
const moduleAccents: Record<number, string> = {
  1: 'var(--cinnabar)',
  2: 'var(--cinnabar-warm)',
  3: '#2a6b9e',
  4: '#c8922a',
  5: '#6b3fa0',
}
const moduleNames: Record<number, string> = {
  1: 'The Architecture of Narrative Music',
  2: 'Rhythm as Primary Reality',
  3: 'Sound as Architecture and Cosmos',
  4: 'The Indian Classical System',
  5: 'The Mathematics of Emergence',
}

const accent = moduleAccents[work.data.module] ?? 'var(--cinnabar)'
const moduleName = moduleNames[work.data.module] ?? ''
---

<ZoneLayout zone="project-track" title={`${work.data.title} — ${work.data.composer} — spicyninja.org`}>
  <SceneDojo slot="scene" />

  <div class="pt-shell" style={`--work-accent: ${accent};`}>

    <!-- SLIDE-AWAY TOC -->
    <aside class="pt-toc" id="pt-toc" aria-label="Works list">
      <div class="pt-toc__header">
        <span class="pt-toc__eyebrow">Project Track</span>
        <a href="/project-track" class="pt-toc__back">← All works</a>
      </div>

      <nav class="pt-toc__list">
        {[1,2,3,4,5].map(mod => (
          <div class="pt-toc__module">
            <span class="pt-toc__module-label">Module {mod}</span>
            {allWorks
              .filter(w => w.data.module === mod)
              .map(w => {
                const active = w.id === work.id
                return (
                  <a
                    href={`/project-track/${w.id}`}
                    class={`pt-toc__item ${active ? 'pt-toc__item--active' : ''}`}
                    aria-current={active ? 'page' : undefined}
                  >
                    <span class="pt-toc__num">{String(w.data.order ?? '').padStart(2,'0')}</span>
                    <span class="pt-toc__name">{w.data.title}</span>
                  </a>
                )
              })
            }
          </div>
        ))}
      </nav>

      <!-- TOC toggle handle -->
      <button class="pt-toc__handle" id="pt-toc-handle" aria-label="Toggle table of contents">
        <span>☰</span>
      </button>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="pt-main" id="pt-main">

      <!-- Work header -->
      <header class="pt-header">
        <p class="pt-header__module">
          <span class="pt-header__mod-num">Module {work.data.module}</span>
          <span class="pt-header__mod-name">{moduleName}</span>
        </p>
        <h1 class="pt-header__title">{work.data.title}</h1>
        <p class="pt-header__byline">
          <span class="pt-header__composer">{work.data.composer}</span>
          <span class="pt-header__year">{work.data.year}</span>
          {work.data.recording && (
            <span class="pt-header__rec">{work.data.recording}</span>
          )}
        </p>
      </header>

      <!-- LAYER 1: LISTEN NOW — YouTube embed + streaming links -->
      <section class="pt-section pt-section--listen">
        <div class="pt-section__label">
          <span class="pt-section__num">01</span>
          <span class="pt-section__name">Listen Now</span>
        </div>

        {work.data.youtubeId ? (
          <div class="pt-embed">
            <iframe
              src={`https://www.youtube.com/embed/${work.data.youtubeId}`}
              title={`${work.data.title} — ${work.data.composer}`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        ) : (
          <div class="pt-embed-search">
            <p class="pt-embed-search__label">Search YouTube for:</p>
            <a
              href={`https://www.youtube.com/results?search_query=${encodeURIComponent(work.data.youtubeQuery)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="pt-embed-search__query"
            >
              {work.data.youtubeQuery} ↗
            </a>
          </div>
        )}

        <div class="pt-links">
          {work.data.youtubeId && (
            <a
              href={`https://www.youtube.com/watch?v=${work.data.youtubeId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="pt-link pt-link--yt"
            >
              YouTube ↗
            </a>
          )}
          {work.data.spotifyUrl && (
            <a
              href={work.data.spotifyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="pt-link pt-link--spotify"
            >
              Spotify ↗
            </a>
          )}
          {work.data.appleMusicUrl && (
            <a
              href={work.data.appleMusicUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="pt-link pt-link--apple"
            >
              Apple Music ↗
            </a>
          )}
        </div>
      </section>

      <!-- LAYER 2: LISTEN FOR -->
      <section class="pt-section pt-section--listenfor">
        <div class="pt-section__label">
          <span class="pt-section__num">02</span>
          <span class="pt-section__name">Listen For</span>
        </div>
        <ul class="pt-checklist">
          {work.data.listenFor.map((item, i) => (
            <li class="pt-checklist__item">
              <span class="pt-checklist__num">{String(i+1).padStart(2,'0')}</span>
              <span class="pt-checklist__text">{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- LAYER 3: PRE-LISTENING CONTEXT (MDX body) -->
      <section class="pt-section pt-section--context">
        <div class="pt-section__label">
          <span class="pt-section__num">03</span>
          <span class="pt-section__name">Pre-Listening Context</span>
        </div>
        <div class="pt-prose">
          <slot />
        </div>
      </section>

      <!-- LAYER 4: WHAT THIS TEACHES -->
      <section class="pt-section pt-section--teaches">
        <div class="pt-section__label">
          <span class="pt-section__num">04</span>
          <span class="pt-section__name">What This Teaches</span>
        </div>
        <ul class="pt-teaches">
          {work.data.teaches.map(item => (
            <li class="pt-teaches__item">{item}</li>
          ))}
        </ul>
      </section>

    </main>
  </div>
</ZoneLayout>

<style>
  /* ── SHELL ── */
  .pt-shell {
    display: flex;
    min-height: 100vh;
    position: relative;
  }

  /* ── TOC ── */
  .pt-toc {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 260px;
    flex-shrink: 0;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    scrollbar-width: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
    z-index: 20;
  }
  .pt-toc::-webkit-scrollbar { display: none; }

  .pt-toc--collapsed { transform: translateX(-244px); }

  .pt-toc__header {
    padding: 1.5rem 1.2rem 1rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .pt-toc__eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--work-accent);
    margin-bottom: 0.4rem;
  }
  .pt-toc__back {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-ghost);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.2s ease;
  }
  .pt-toc__back:hover { color: var(--text-muted); }

  .pt-toc__list { padding: 1rem 0; flex: 1; }

  .pt-toc__module {
    margin-bottom: 1rem;
    padding: 0 1.2rem;
  }
  .pt-toc__module-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-ghost);
    margin-bottom: 0.4rem;
    opacity: 0.5;
  }

  .pt-toc__item {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.45rem 0;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.3;
    border-left: 2px solid transparent;
    padding-left: 0.5rem;
    margin-left: -0.7rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .pt-toc__item:hover { color: var(--text-primary); border-left-color: var(--border-hi); }
  .pt-toc__item--active {
    color: var(--work-accent) !important;
    border-left-color: var(--work-accent) !important;
  }
  .pt-toc__num {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--text-ghost);
    flex-shrink: 0;
    opacity: 0.5;
  }
  .pt-toc__item--active .pt-toc__num { color: var(--work-accent); opacity: 0.7; }

  /* TOC handle — fixed to viewport, always visible */
  .pt-toc__handle {
    position: fixed;
    top: 50%;
    left: 260px;
    transform: translateY(-50%);
    width: 18px;
    height: 48px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-left: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 0.6rem;
    color: var(--text-ghost);
    transition: color 0.2s ease, left 0.4s cubic-bezier(0.4,0,0.2,1);
    z-index: 30;
  }
  .pt-toc__handle:hover { color: var(--text-primary); }
  .pt-toc__handle--collapsed { left: 52px; }

  /* ── MAIN ── */
  .pt-main {
    flex: 1;
    min-width: 0;
    padding: 3rem 3.5rem 6rem;
    max-width: 800px;
    transition: padding-left 0.4s cubic-bezier(0.4,0,0.2,1);
  }

  /* ── HEADER ── */
  .pt-header { margin-bottom: 3rem; }
  .pt-header__module {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }
  .pt-header__mod-num {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--work-accent);
  }
  .pt-header__mod-name {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-ghost);
  }
  .pt-header__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 0.95;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  .pt-header__byline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }
  .pt-header__composer { color: var(--text-secondary); }
  .pt-header__rec { color: var(--text-ghost); font-size: 0.6rem; width: 100%; margin-top: 0.2rem; }

  /* ── SECTIONS ── */
  .pt-section {
    margin-bottom: 3.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--border);
  }
  .pt-section:last-child { border-bottom: none; }

  .pt-section__label {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .pt-section__num {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--work-accent);
    opacity: 0.6;
  }
  .pt-section__name {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-ghost);
  }

  /* ── YOUTUBE EMBED ── */
  .pt-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: var(--bg-secondary);
    margin-bottom: 1rem;
  }
  .pt-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .pt-embed-search {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--work-accent);
    padding: 1.2rem 1.5rem;
    margin-bottom: 1rem;
  }
  .pt-embed-search__label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-ghost);
    margin-bottom: 0.5rem;
  }
  .pt-embed-search__query {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--work-accent);
    text-decoration: none;
  }
  .pt-embed-search__query:hover { text-decoration: underline; }

  /* ── STREAMING LINKS ── */
  .pt-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .pt-link {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .pt-link:hover { border-color: var(--work-accent); color: var(--work-accent); }
  .pt-link--yt:hover { border-color: #ff4444; color: #ff4444; }
  .pt-link--spotify:hover { border-color: #1db954; color: #1db954; }

  /* ── LISTEN-FOR CHECKLIST ── */
  .pt-checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pt-checklist__item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 1.2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--work-accent);
  }
  .pt-checklist__num {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    color: var(--work-accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
    opacity: 0.6;
  }
  .pt-checklist__text {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── PROSE (MDX body) ── */
  .pt-prose {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.82;
    color: var(--text-secondary);
    max-width: 68ch;
  }
  .pt-prose h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--text-primary);
    margin: 2.5rem 0 1rem;
    line-height: 1.1;
  }
  .pt-prose h2::before {
    content: '';
    display: block;
    width: 2rem;
    height: 2px;
    background: var(--work-accent);
    margin-bottom: 0.7rem;
    opacity: 0.5;
  }
  .pt-prose p { margin-bottom: 1.2rem; }
  .pt-prose em { color: var(--text-primary); font-style: italic; }
  .pt-prose strong { color: var(--text-primary); font-weight: 500; }

  /* ── TEACHES LIST ── */
  .pt-teaches {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .pt-teaches__item {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 0.7rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    line-height: 1.5;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .pt-toc { display: none; }
    .pt-main { padding: 2rem 1.5rem 4rem; }
    .pt-teaches { grid-template-columns: 1fr; }
  }
</style>

<script>
  const toc = document.getElementById('pt-toc')
  const handle = document.getElementById('pt-toc-handle')
  let collapsed = false

  function setCollapsed(state: boolean) {
    collapsed = state
    toc?.classList.toggle('pt-toc--collapsed', collapsed)
    handle?.classList.toggle('pt-toc__handle--collapsed', collapsed)
  }

  handle?.addEventListener('click', (e) => {
    e.stopPropagation()
    setCollapsed(!collapsed)
  })

  let lastY = window.scrollY
  let scrollTimer: ReturnType<typeof setTimeout> | null = null

  window.addEventListener('scroll', () => {
    if (scrollTimer) clearTimeout(scrollTimer)
    scrollTimer = setTimeout(() => {
      const y = window.scrollY
      const scrollingDown = y > lastY
      lastY = y
      if (scrollingDown && y > 400 && !collapsed) {
        setCollapsed(true)
      }
    }, 150)
  }, { passive: true })
</script>
