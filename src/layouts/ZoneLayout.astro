---
import Base from './Base.astro'

interface Props {
  zone: 'project-track' | 'montessori' | 'fundamentals' |
        'journey' | 'journal' | 'blog' | 'project' | 'community'
  title?: string
  description?: string
}

const { zone, title, description } = Astro.props

const zoneAccents: Record<string, { accent: string; dim: string; glow: string }> = {
  'project-track': { accent: '#E34234', dim: 'rgba(227,66,52,0.15)',   glow: 'rgba(227,66,52,0.08)'  },
  'montessori':    { accent: '#E8A020', dim: 'rgba(232,160,32,0.15)',  glow: 'rgba(232,160,32,0.08)' },
  'fundamentals':  { accent: '#E8A020', dim: 'rgba(232,160,32,0.15)',  glow: 'rgba(232,160,20,0.06)' },
  'journey':       { accent: '#c87840', dim: 'rgba(200,120,64,0.15)',  glow: 'rgba(200,120,64,0.08)' },
  'journal':       { accent: '#c8b490', dim: 'rgba(200,180,144,0.15)', glow: 'rgba(200,180,144,0.06)'},
  'blog':          { accent: '#E34234', dim: 'rgba(227,66,52,0.12)',   glow: 'rgba(227,66,52,0.06)'  },
  'project':       { accent: '#6b3fa0', dim: 'rgba(107,63,160,0.15)',  glow: 'rgba(107,63,160,0.08)' },
  'community':     { accent: '#b87333', dim: 'rgba(184,115,51,0.15)',  glow: 'rgba(184,115,51,0.08)' },
}

const a = zoneAccents[zone] ?? zoneAccents['project-track']
---

<Base title={title} description={description}>
  <div
    class="zone-shell"
    data-zone={zone}
    style={`--zone-accent:${a.accent};--zone-accent-dim:${a.dim};--zone-glow:${a.glow};`}
  >
    <!-- Scene: full-viewport crisp silhouette illustration, fixed behind -->
    <div class="zone-scene">
      <slot name="scene" />
    </div>

    <!-- Spacer pushes content below the scene viewport -->
    <div class="zone-spacer" aria-hidden="true"></div>

    <!-- Content: solid ground slides up over the scene on scroll -->
    <div class="zone-content">
      <slot />
    </div>
  </div>
</Base>

<style>
  .zone-shell {
    position: relative;
    min-height: 100vh;
  }

  /* Scene: fixed, full viewport, sharp and unobscured */
  .zone-scene {
    position: fixed;
    inset: 0 0 0 52px;
    z-index: 0;
    pointer-events: none;
    /* No blur, no overlay — the scene renders at full opacity */
  }

  @media (max-width: 768px) {
    .zone-scene { inset: 52px 0 0 0; }
  }

  /*
    Spacer: one viewport height of transparent space so the scene
    is visible before content begins. As you scroll, content
    slides up from below the fold over the scene.
  */
  .zone-spacer {
    height: 60vh;
    pointer-events: none;
  }

  /*
    Content: solid background — no gradient fog, no see-through.
    The scene is visible above it (in the spacer zone), not through it.
    Sharp edge where content meets scene.
  */
  .zone-content {
    position: relative;
    z-index: 10;
    background: var(--bg-primary);
    border-top: 1px solid var(--zone-accent-dim);
    min-height: 100vh;
    /* No overflow:hidden here — sticky TOC children need the page as scroll context */
    overflow: visible;
  }

  /* Zone accent application */
  .zone-shell .eyebrow { color: var(--zone-accent); opacity: 0.8; }
  .zone-shell .card-accent { border-left-color: var(--zone-accent); }

  /* RGB values for dark/light theme */
  :root,
  [data-theme="dark"]  { --bg-primary-rgb: 42,26,10;    }
  [data-theme="light"] { --bg-primary-rgb: 245,237,224; }
</style>
