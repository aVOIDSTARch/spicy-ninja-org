---
import '../styles/global.css'
import Nav from '../components/nav/Nav.astro'
import ThemeToggle from '../components/ui/ThemeToggle.astro'
import AuthIsland from '../components/ui/AuthIsland.astro'
import RawIdeasPanel from '../components/ui/RawIdeasPanel.astro'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'spicyninja.org',
  description = 'A public education in making Jus Pulsus — music theory, composition, and the art of listening.',
} = Astro.props
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Kaisei+Decol:wght@400;700&family=Shippori+Mincho:wght@400;500;600&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sn-theme') || 'dark'
        document.documentElement.setAttribute('data-theme', theme)
      })()
    </script>
  </head>
  <body>
    <Nav />
    <div class="page-shell">
      <slot />
    </div>
    <ThemeToggle />
    <AuthIsland />
    <RawIdeasPanel />
  </body>
</html>

<style is:global>
  .page-shell { margin-left: 52px; min-height: 100vh; }
  @media (max-width: 768px) {
    .page-shell { margin-left: 0; padding-top: 52px; }
  }
  body.sn-authed .page-shell { padding-bottom: 42px; }
</style>
