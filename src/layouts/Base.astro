---
/*
  Base.astro
  Root HTML shell for every page on spicyninja.org.

  - Inlines theme detection script before <body> to prevent flash
  - Imports global CSS
  - Renders ThemeToggle lantern (fixed position, visible on all pages)
  - Slot for page content
*/

import '../styles/global.css'
import ThemeToggle from '../components/ui/ThemeToggle.astro'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'spicyninja.org',
  description = 'A public education in making Jus Pulsus — music theory, composition, and the art of listening.',
} = Astro.props
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      Anti-flash theme script — runs synchronously before paint.
      Reads localStorage and sets data-theme on <html> immediately.
      Must be inline, must be in <head>, must not be deferred.
    -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('sn-theme') || 'dark'
        document.documentElement.setAttribute('data-theme', theme)
      })()
    </script>
  </head>
  <body>
    <slot />
    <ThemeToggle />
  </body>
</html>
