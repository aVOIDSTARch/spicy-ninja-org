---
import { getCollection, render } from 'astro:content'
import ProjectTrackLayout from '../../layouts/ProjectTrackLayout.astro'

export async function getStaticPaths() {
  const works = await getCollection('project-track', ({ data }) => !data.draft)
  return works.map(work => ({
    params: { slug: work.id },
    props: { work },
  }))
}

const { work } = Astro.props
const { Content } = await render(work)
---

<ProjectTrackLayout work={work}>
  <Content />
</ProjectTrackLayout>
