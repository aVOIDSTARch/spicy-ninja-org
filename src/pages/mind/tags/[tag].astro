---
export const prerender = true;
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import IdeaCard from "../../../components/IdeaCard.astro";
import "../../../styles/global.css";

export const getStaticPaths = (async () => {
  const ideas = await getCollection("mind");
  const tags = new Set<string>();

  ideas.forEach((idea) => {
    idea.data.hashtags.forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => ({
    params: { tag: tag.replace("#", "") },
    props: {
      tag,
      ideas: ideas.filter((idea) => idea.data.hashtags.includes(tag)),
    },
  }));
}) satisfies GetStaticPaths;

const { tag, ideas } = Astro.props;
const sortedIdeas = ideas.sort(
  (a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf()
);
---

<html lang="en">
  <head>
    <BaseHead
      title={`${tag} | Tags | Mind`}
      description={`Ideas tagged with ${tag}`}
    />
  </head>
  <body>
    <Header />
    <main class="w-full max-w-[960px] mx-auto p-4">
      <div class="mb-12 border-b-4 border-black pb-8">
        <div class="mb-4">
          <a
            href="/mind/tags"
            class="text-sm font-mono text-accent hover:underline"
          >
            ← All Tags
          </a>
        </div>
        <h1
          class="text-4xl md:text-5xl font-bold font-mono uppercase mb-4 leading-none"
        >
          {tag}
        </h1>
        <p
          class="font-body text-lg text-gray-dark leading-relaxed max-w-[720px]"
        >
          {sortedIdeas.length}
          {sortedIdeas.length === 1 ? "idea" : "ideas"} tagged with {tag}
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6">
        {
          sortedIdeas.map((idea) => (
            <IdeaCard
              title={idea.data.title}
              summary={idea.data.summary}
              slug={idea.id}
              updatedDate={idea.data.updatedDate}
              hashtags={idea.data.hashtags}
              thoughtCount={idea.data.thoughts.length}
            />
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>
