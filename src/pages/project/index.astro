---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneMountain from '../../components/scenes/SceneMountain.astro'
import { getCollection } from 'astro:content'

const docs = (await getCollection('project', ({ data }) => !data.draft).catch(() => []))
  .sort((a: any, b: any) => a.data.order - b.data.order)
---

<ZoneLayout zone="project" title="Project — spicyninja.org">
  <SceneMountain slot="scene" />

  <div style="padding: 12vh 3.5rem 6rem; max-width: 820px;">
    <p class="eyebrow">jus pulsus</p>
    <h1 class="hero-heading" style="margin-bottom:1rem;">The Project</h1>
    <p style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
              max-width:580px; line-height:1.85; margin-bottom:3.5rem;">
      A 90-minute programmatic electronic suite. A creation myth, a history of music,
      and an ontological love story — three things viewed from the same angle.
    </p>

    {docs.length === 0 ? (
      <div style="border:1px solid var(--border); border-left:3px solid #6b3fa0;
                  padding:2rem; background:var(--bg-card);">
        <p style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.15em;
                   text-transform:uppercase; color:var(--text-ghost); margin-bottom:0.6rem;">
          Documentation in progress
        </p>
        <p style="font-family:var(--font-body); color:var(--text-muted); font-size:0.9rem; line-height:1.7;">
          Vision, structure, characters, and decisions are documented in the project repository
          and will appear here as they are published.
        </p>
      </div>
    ) : (
      <div style="display:grid; gap:1px; background:var(--border);">
        {docs.map((doc: any) => (
          <a href={`/project/${doc.id.replace('.mdx','')}`}
             style="display:grid; grid-template-columns:3px 1fr; background:var(--bg-card);
                    text-decoration:none; transition:background 0.2s ease;"
             onmouseover="this.style.background='var(--bg-raised)'"
             onmouseout="this.style.background='var(--bg-card)'">
            <div style="background:#6b3fa0;" />
            <div style="padding:1.5rem 2rem;">
              <span style="font-family:var(--font-mono); font-size:0.5rem; letter-spacing:0.2em;
                            text-transform:uppercase; color:var(--text-ghost); display:block; margin-bottom:0.4rem;">
                {doc.data.status}
              </span>
              <span style="font-family:var(--font-display); font-size:1.3rem; color:var(--text-primary);
                            display:block; margin-bottom:0.3rem;">{doc.data.title}</span>
              {doc.data.description && (
                <span style="font-family:var(--font-mono); font-size:0.62rem; color:var(--text-muted);">
                  {doc.data.description}
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</ZoneLayout>
