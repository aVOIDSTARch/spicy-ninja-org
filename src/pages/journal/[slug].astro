---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneGarden from '../../components/scenes/SceneGarden.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const entries = await getCollection('listening-journal', ({ data }) => !data.draft).catch(() => [])
  return entries.map((entry: any) => ({
    params: { slug: entry.id.replace('.mdx','') },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)

const layers = [
  { key: 'naked',      label: 'Naked',      desc: 'First listen — pure reception, no analysis',  accent: '#2a6b9e' },
  { key: 'inhabited',  label: 'Inhabited',  desc: 'Active listening — what you heard',           accent: '#6b3fa0' },
  { key: 'anatomical', label: 'Anatomical', desc: 'Structural analysis — how it works',          accent: '#c8922a' },
  { key: 'notebook',   label: 'Notebook',   desc: 'Raw notes — ideas, fragments, connections',   accent: 'var(--cinnabar)' },
] as const
---

<ZoneLayout zone="journal" title={`${entry.data.title} — Journal — spicyninja.org`}>
  <SceneGarden slot="scene" />

  <div style="padding: 10vh 3.5rem 6rem; max-width: 820px;">
    <a href="/journal"
       style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.15em;
              color:var(--text-ghost); text-decoration:none; display:inline-block; margin-bottom:2.5rem;">
      ← Journal
    </a>

    <header style="margin-bottom:3rem;">
      <p style="font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.28em;
                 text-transform:uppercase; color:var(--zone-accent); margin-bottom:0.6rem;">
        {new Date(entry.data.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
      </p>
      <h1 style="font-family:var(--font-display); font-weight:700; font-size:clamp(2rem,5vw,3rem);
                  color:var(--text-primary); line-height:1.05; margin-bottom:0.8rem;">
        {entry.data.title}
      </h1>
      <p style="font-family:var(--font-mono); font-size:0.65rem; color:var(--text-muted); letter-spacing:0.1em;">
        {entry.data.composer} — {entry.data.work}
        {entry.data.module && <span style="margin-left:1.5rem; color:var(--text-ghost);">{entry.data.module}</span>}
      </p>
    </header>

    <div style="display:grid; gap:1px; background:var(--border); margin-bottom:3rem;">
      {layers.map(layer => {
        const text = (entry.data.layers as any)?.[layer.key]
        if (!text) return null
        return (
          <div style={`background:var(--bg-card); border-left:3px solid ${layer.accent};`}>
            <div style="padding:1.2rem 1.5rem 0.6rem;">
              <p style={`font-family:var(--font-mono); font-size:0.5rem; letter-spacing:0.25em;
                          text-transform:uppercase; color:${layer.accent}; margin-bottom:0.15rem;`}>
                {layer.label}
              </p>
              <p style="font-family:var(--font-mono); font-size:0.58rem; color:var(--text-ghost); letter-spacing:0.08em;">
                {layer.desc}
              </p>
            </div>
            <div style="padding:0 1.5rem 1.5rem; font-family:var(--font-body); font-size:0.95rem;
                          color:var(--text-secondary); line-height:1.8; white-space:pre-wrap;">
              {text}
            </div>
          </div>
        )
      })}
    </div>

    <div class="journal-prose"><Content /></div>
  </div>
</ZoneLayout>

<style>
  .journal-prose {
    font-family: var(--font-body); font-size: 1rem;
    line-height: 1.82; color: var(--text-secondary); max-width: 68ch;
  }
  .journal-prose p { margin-bottom: 1.2rem; }
  .journal-prose h2 {
    font-family: var(--font-display); font-weight: 400; font-size: 1.4rem;
    color: var(--text-primary); margin: 2rem 0 0.8rem;
  }
</style>
