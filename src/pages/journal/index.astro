---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneGarden from '../../components/scenes/SceneGarden.astro'
import { getCollection } from 'astro:content'

// Journal is login-gated — all entries are draft:true until created
// For now show empty state; entries will appear when content is dropped in
const entries = await getCollection('listening-journal', ({ data }) => !data.draft)
  .catch(() => [])
entries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
---

<ZoneLayout zone="journal" title="Listening Journal — spicyninja.org">
  <SceneGarden slot="scene" />

  <div style="padding: 12vh 3.5rem 6rem; max-width: 820px;">
    <p class="eyebrow">listening sessions</p>
    <h1 class="hero-heading" style="margin-bottom:1rem;">Listening Journal</h1>
    <p style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
              max-width:580px; line-height:1.85; margin-bottom:3.5rem;">
      Four layers per session: Naked, Inhabited, Anatomical, Notebook.
      Each entry is a record of a listening session and how it changed the work.
    </p>

    {entries.length === 0 ? (
      <div style="border:1px solid var(--border); border-left:3px solid var(--zone-accent);
                  padding:2rem; background:var(--bg-card);">
        <p style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.15em;
                   text-transform:uppercase; color:var(--text-ghost); margin-bottom:0.6rem;">
          No entries yet
        </p>
        <p style="font-family:var(--font-body); color:var(--text-muted); font-size:0.9rem; line-height:1.7;">
          Listening journal entries are dropped in as MDX files under
          <code style="font-family:var(--font-mono); font-size:0.8em; color:var(--zone-accent);">
            src/content/listening-journal/
          </code>.
          Each entry follows the four-layer format.
        </p>
      </div>
    ) : (
      <div style="display:grid; gap:1px; background:var(--border);">
        {entries.map(entry => (
          <a href={`/journal/${entry.id.replace('.mdx','')}`}
             style="display:block; background:var(--bg-card); padding:1.5rem;
                    text-decoration:none; border-left:3px solid var(--zone-accent);
                    transition:background 0.2s ease;"
             onmouseover="this.style.background='var(--bg-raised)'"
             onmouseout="this.style.background='var(--bg-card)'">
            <span style="font-family:var(--font-mono); font-size:0.55rem; letter-spacing:0.2em;
                          text-transform:uppercase; color:var(--text-ghost); display:block; margin-bottom:0.4rem;">
              {new Date(entry.data.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
            </span>
            <span style="font-family:var(--font-display); font-size:1.2rem; color:var(--text-primary);
                          display:block; margin-bottom:0.25rem;">
              {entry.data.title}
            </span>
            <span style="font-family:var(--font-mono); font-size:0.62rem; color:var(--text-muted);">
              {entry.data.composer} — {entry.data.work}
            </span>
          </a>
        ))}
      </div>
    )}
  </div>
</ZoneLayout>
