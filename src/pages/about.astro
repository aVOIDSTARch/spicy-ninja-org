---
import ZoneLayout from '../layouts/ZoneLayout.astro'
import SceneMountain from '../components/scenes/SceneMountain.astro'
---

<ZoneLayout zone="project" title="About — spicyninja.org">
  <SceneMountain slot="scene" />

  <div style="padding: 12vh 3.5rem 6rem; max-width: 820px;">
    <p class="eyebrow">about</p>
    <h1 class="hero-heading" style="margin-bottom:2rem;">spicyninja.org</h1>

    <div style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
                line-height:1.85; max-width:620px;">
      <p style="margin-bottom:1.5rem;">
        This site documents the process of making <em>Jus Pulsus</em> —
        a 90-minute programmatic electronic suite currently in development.
      </p>
      <p style="margin-bottom:1.5rem;">
        It is simultaneously a creation myth, a history of music, and an ontological
        love story. Three things viewed from the same angle.
      </p>
      <p style="margin-bottom:1.5rem;">
        The philosophical engine is Octavia E. Butler's Earthseed principle.
        The allegorical spine is Orpheus and Eurydice. The structural model is
        Prokofiev's — but in the language of electronic music, with roots in 90s EDM
        and branches reaching into Indian classical, West African drumming,
        Sufi devotional music, and Chinese classical aesthetics.
      </p>
      <p style="margin-bottom:3rem;">
        This is not a remix. It is not a genre exercise. It is a human creative work
        made by a specific person with a specific history and a specific unfulfilled
        creative need that has waited since the late 1990s to find its form.
        The AI collaboration is documented transparently and completely.
      </p>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1px;
                background:var(--border); max-width:620px;">
      <div style="background:var(--bg-card); padding:1.2rem 1.5rem;">
        <p style="font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.25em;
                   text-transform:uppercase; color:var(--text-ghost); margin-bottom:0.5rem;">Project</p>
        <a href="/project"
           style="font-family:var(--font-display); font-size:1.1rem;
                  color:var(--text-primary); text-decoration:none;">
          Jus Pulsus →
        </a>
      </div>
      <div style="background:var(--bg-card); padding:1.2rem 1.5rem;">
        <p style="font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.25em;
                   text-transform:uppercase; color:var(--text-ghost); margin-bottom:0.5rem;">Contact</p>
        <a href="mailto:jus-pulsus@hecarrieswater.com"
           style="font-family:var(--font-display); font-size:1.1rem;
                  color:var(--text-primary); text-decoration:none;">
          jus-pulsus@hecarrieswater.com
        </a>
      </div>
    </div>
  </div>
</ZoneLayout>
