---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneScholars from '../../components/scenes/SceneScholars.astro'
import { getCollection } from 'astro:content'

const allLessons = await getCollection('fundamentals', ({ data }) => !data.draft)

const branches = [
  { slug: 'bach-math',      label: 'Bach Math',           desc: 'Mathematical operations on musical material. Retrograde, inversion, augmentation, stretto.',  accent: '#c8922a' },
  { slug: 'markov-chains',  label: 'Markov Chains',        desc: 'Stochastic composition. Probability tables, weighted random, musical memory.',                accent: '#6b3fa0' },
  { slug: 'music-theory',   label: 'Music Theory',         desc: 'Intervals, modes, ragas, the harmonic series. The minimum theory load-bearing for the work.', accent: '#2a6b9e' },
  { slug: 'composition',    label: 'Composition',          desc: 'Large-scale form, leitmotif architecture, emergence, structural events and their aftermath.',   accent: 'var(--cinnabar)' },
  { slug: 'characters',     label: 'Character Development', desc: 'Timbral casting, development arcs, superpartner relationships, the interview.',              accent: '#3a7d44' },
]
---

<ZoneLayout zone="fundamentals" title="Fundamentals — spicyninja.org">
  <SceneScholars slot="scene" />

  <div style="padding: 12vh 3.5rem 6rem; max-width: 960px;">
    <p class="eyebrow">foundations</p>
    <h1 class="hero-heading" style="margin-bottom: 1rem;">Fundamentals</h1>
    <p style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
              max-width:580px; line-height:1.85; margin-bottom:3.5rem;">
      Five branches of compositional technique. Each is a general course — illustrated with Sonic Pi,
      grounded in tradition, cross-referenced to the project in development.
    </p>

    <div style="display:grid; gap:1px; background:var(--border);">
      {branches.map(branch => {
        const lessons = allLessons
          .filter(l => l.data.branch === branch.slug)
          .sort((a, b) => a.data.order - b.data.order)
        return (
          <a
            href={`/fundamentals/${branch.slug}`}
            style={`display:grid; grid-template-columns:3px 1fr auto; background:var(--bg-card);
                    text-decoration:none; transition:background 0.2s ease;`}
            onmouseover="this.style.background='var(--bg-raised)'"
            onmouseout="this.style.background='var(--bg-card)'"
          >
            <div style={`background:${branch.accent};`} />
            <div style="padding:1.5rem 1.8rem;">
              <span style={`font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.28em;
                            text-transform:uppercase; color:${branch.accent}; display:block; margin-bottom:0.5rem;`}>
                {branch.label}
              </span>
              <span style="font-family:var(--font-display); font-size:1.3rem; color:var(--text-primary);
                            display:block; margin-bottom:0.4rem;">
                {branch.desc}
              </span>
            </div>
            <div style="padding:1.5rem 1.8rem; display:flex; align-items:center;">
              <span style="font-family:var(--font-mono); font-size:0.6rem; color:var(--text-ghost);
                            letter-spacing:0.15em;">
                {lessons.length} lesson{lessons.length !== 1 ? 's' : ''}
              </span>
            </div>
          </a>
        )
      })}
    </div>
  </div>
</ZoneLayout>
