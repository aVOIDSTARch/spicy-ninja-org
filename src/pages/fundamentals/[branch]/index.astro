---
import ZoneLayout from '../../../layouts/ZoneLayout.astro'
import SceneScholars from '../../../components/scenes/SceneScholars.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const branches = ['bach-math', 'markov-chains', 'music-theory', 'composition', 'characters']
  return branches.map(branch => ({ params: { branch } }))
}

const { branch } = Astro.params

const branchMeta: Record<string, { label: string; accent: string }> = {
  'bach-math':      { label: 'Bach Math',            accent: '#c8922a' },
  'markov-chains':  { label: 'Markov Chains',         accent: '#6b3fa0' },
  'music-theory':   { label: 'Music Theory',          accent: '#2a6b9e' },
  'composition':    { label: 'Composition',           accent: 'var(--cinnabar)' },
  'characters':     { label: 'Character Development', accent: '#3a7d44' },
}

const meta = branchMeta[branch] ?? { label: branch, accent: 'var(--cinnabar)' }

const lessons = (await getCollection('fundamentals', ({ data }) =>
  !data.draft && data.branch === branch
)).sort((a, b) => a.data.order - b.data.order)

// Separate overview (order 0) from numbered lessons
const overview = lessons.find(l => l.data.order === 0)
const courseLessons = lessons.filter(l => l.data.order > 0)
---

<ZoneLayout zone="fundamentals" title={`${meta.label} — Fundamentals — spicyninja.org`}>
  <SceneScholars slot="scene" />

  <div style="padding: 12vh 3.5rem 6rem; max-width: 820px;">

    <a href="/fundamentals"
       style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.15em;
              color:var(--text-ghost); text-decoration:none; display:inline-block; margin-bottom:2rem;">
      ← Fundamentals
    </a>

    <p style={`font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.28em;
               text-transform:uppercase; color:${meta.accent}; margin-bottom:0.6rem;`}>
      Branch
    </p>
    <h1 class="hero-heading" style="margin-bottom:1.5rem;">{meta.label}</h1>

    {overview && (
      <p style="font-family:var(--font-body); font-size:1rem; color:var(--text-secondary);
                line-height:1.85; max-width:620px; margin-bottom:3rem;">
        {overview.data.description}
      </p>
    )}

    {courseLessons.length > 0 && (
      <div style="display:grid; gap:1px; background:var(--border);">
        {courseLessons.map((lesson, i) => (
          <a
            href={`/fundamentals/${branch}/${lesson.id.split('/').pop()?.replace('.mdx','')}`}
            style={`display:grid; grid-template-columns:auto 1fr; background:var(--bg-card);
                    text-decoration:none; transition:background 0.2s ease;`}
            onmouseover="this.style.background='var(--bg-raised)'"
            onmouseout="this.style.background='var(--bg-card)'"
          >
            <div style={`width:3px; background:${meta.accent}; opacity:0.4;`} />
            <div style="padding:1.2rem 1.5rem;">
              <span style="font-family:var(--font-mono); font-size:0.5rem; letter-spacing:0.2em;
                            text-transform:uppercase; color:var(--text-ghost); display:block; margin-bottom:0.4rem;">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span style="font-family:var(--font-display); font-size:1.15rem; color:var(--text-primary);
                            display:block; margin-bottom:0.25rem;">
                {lesson.data.title}
              </span>
              {lesson.data.description && (
                <span style="font-family:var(--font-mono); font-size:0.62rem; color:var(--text-muted);
                              letter-spacing:0.05em; line-height:1.5;">
                  {lesson.data.description}
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</ZoneLayout>
