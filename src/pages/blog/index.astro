---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneVillage from '../../components/scenes/SceneVillage.astro'
---

<ZoneLayout zone="blog" title="Blog — spicyninja.org">
  <SceneVillage slot="scene" />
  <div style="padding: 14vh 4rem 6rem; max-width: 820px;">
    <p class="eyebrow">process journal</p>
    <h1 class="hero-heading" style="margin-bottom: 1rem;">
      The Blog
    </h1>
    <p style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
              max-width:560px; line-height:1.85; margin-top:1.5rem;">
      Personal, multidimensional. Progress, experience, and honest accounting of what it takes to learn to make something like this.
    </p>
    <p style="font-family:var(--font-mono); font-size:0.62rem; letter-spacing:0.25em;
              text-transform:uppercase; color:var(--zone-accent); margin-top:3rem; opacity:0.6;">
      coming soon
    </p>
  </div>
</ZoneLayout>
