---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneVillage from '../../components/scenes/SceneVillage.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft)
  .catch(() => [])
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())

const formatAccents: Record<string, string> = {
  'reflection':   '#6b3fa0',
  'session-log':  '#2a6b9e',
  'breakthrough': 'var(--cinnabar)',
  'question':     '#c8922a',
  'reference':    '#3a7d44',
  'sketch':       '#9a6b4a',
}
---

<ZoneLayout zone="blog" title="Blog — spicyninja.org">
  <SceneVillage slot="scene" />

  <div style="padding: 12vh 3.5rem 6rem; max-width: 960px;">
    <p class="eyebrow">process journal</p>
    <h1 class="hero-heading" style="margin-bottom:1rem;">The Blog</h1>
    <p style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
              max-width:580px; line-height:1.85; margin-bottom:3.5rem;">
      Personal, multidimensional. Six card formats — reflection, session log, breakthrough,
      question, reference, sketch. No two entries feel the same.
    </p>

    {posts.length === 0 ? (
      <div style="border:1px solid var(--border); border-left:3px solid var(--zone-accent);
                  padding:2rem; background:var(--bg-card);">
        <p style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.15em;
                   text-transform:uppercase; color:var(--text-ghost); margin-bottom:0.6rem;">
          No posts yet
        </p>
        <p style="font-family:var(--font-body); color:var(--text-muted); font-size:0.9rem; line-height:1.7;">
          Blog posts are written offline as MDX files and dropped into
          <code style="font-family:var(--font-mono); font-size:0.8em; color:var(--zone-accent);">
            src/content/blog/
          </code>.
          Each post has a format field that determines how the card renders.
        </p>
      </div>
    ) : (
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border);">
        {posts.map(post => {
          const accent = formatAccents[post.data.format] ?? 'var(--cinnabar)'
          return (
            <a href={`/blog/${post.id.replace('.mdx','')}`}
               style={`display:block; background:var(--bg-card); padding:1.5rem;
                       text-decoration:none; border-top:3px solid ${accent};
                       transition:background 0.2s ease;`}
               onmouseover="this.style.background='var(--bg-raised)'"
               onmouseout="this.style.background='var(--bg-card)'">
              <div style="display:flex; align-items:center; gap:0.8rem; margin-bottom:0.8rem;">
                <span style={`font-family:var(--font-mono); font-size:0.5rem; letter-spacing:0.18em;
                              text-transform:uppercase; color:${accent};`}>
                  {post.data.format}
                </span>
                <span style="font-family:var(--font-mono); font-size:0.5rem; color:var(--text-ghost);">
                  {new Date(post.data.date).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' })}
                </span>
              </div>
              <span style="font-family:var(--font-display); font-size:1.2rem; color:var(--text-primary);
                            display:block; margin-bottom:0.5rem; line-height:1.2;">
                {post.data.title}
              </span>
              <span style="font-family:var(--font-body); font-size:0.85rem; color:var(--text-muted);
                            line-height:1.6; display:block;">
                {post.data.description}
              </span>
            </a>
          )
        })}
      </div>
    )}
  </div>
</ZoneLayout>
