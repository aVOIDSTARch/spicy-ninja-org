---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneVillage from '../../components/scenes/SceneVillage.astro'
---

<ZoneLayout zone="blog" title="New Post — Blog — spicyninja.org">
  <SceneVillage slot="scene" />

  <div class="bc-shell">
    <a href="/blog" style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.15em;
       color:var(--text-ghost);text-decoration:none;display:inline-block;margin-bottom:2rem;">← Blog</a>

    <h1 class="bc-title">New Post</h1>

    <!-- FORMAT PICKER -->
    <div class="bc-section">
      <h2 class="bc-section-title">Format</h2>
      <p class="bc-section-desc">Format determines how the card renders on the blog index.</p>
      <div class="bc-formats" id="bc-formats">
        <button class="bc-format-btn" data-format="reflection"  style="--fmt-accent:#6b3fa0">
          <span class="bc-format-label">Reflection</span>
          <span class="bc-format-desc">Long-form, considered. Let it breathe.</span>
        </button>
        <button class="bc-format-btn" data-format="session-log" style="--fmt-accent:#2a6b9e">
          <span class="bc-format-label">Session Log</span>
          <span class="bc-format-desc">Chronological. Timestamps welcome.</span>
        </button>
        <button class="bc-format-btn" data-format="breakthrough" style="--fmt-accent:var(--cinnabar)">
          <span class="bc-format-label">Breakthrough</span>
          <span class="bc-format-desc">State it directly, then unpack.</span>
        </button>
        <button class="bc-format-btn" data-format="question" style="--fmt-accent:#c8922a">
          <span class="bc-format-label">Question</span>
          <span class="bc-format-desc">The question IS the post.</span>
        </button>
        <button class="bc-format-btn" data-format="reference" style="--fmt-accent:#3a7d44">
          <span class="bc-format-label">Reference</span>
          <span class="bc-format-desc">Source, link, and why it matters.</span>
        </button>
        <button class="bc-format-btn" data-format="sketch" style="--fmt-accent:#9a6b4a">
          <span class="bc-format-label">Sketch</span>
          <span class="bc-format-desc">Loose. Fragments allowed.</span>
        </button>
      </div>
    </div>

    <!-- META -->
    <div class="bc-section">
      <h2 class="bc-section-title">Meta</h2>
      <div class="bc-meta-grid">
        <div class="bc-field bc-field--full">
          <label class="bc-label" for="bc-title">Title</label>
          <input class="bc-input" id="bc-title" type="text" placeholder="Post title" />
        </div>
        <div class="bc-field bc-field--full">
          <label class="bc-label" for="bc-desc">Description</label>
          <input class="bc-input" id="bc-desc" type="text" placeholder="One sentence shown on the index card" />
        </div>
        <div class="bc-field">
          <label class="bc-label" for="bc-date">Date</label>
          <input class="bc-input" id="bc-date" type="date" />
        </div>
        <div class="bc-field">
          <label class="bc-label" for="bc-derived">Derived from journal entry (optional)</label>
          <input class="bc-input" id="bc-derived" type="text" placeholder="slug of source journal entry" />
        </div>
      </div>
    </div>

    <!-- BODY -->
    <div class="bc-section">
      <h2 class="bc-section-title">Body</h2>
      <p class="bc-section-desc" id="bc-content-hint">Select a format above to see guidance.</p>

      <div class="bc-body-field">
        <label class="bc-label" for="bc-body">Content (Markdown)</label>
        <textarea class="bc-textarea" id="bc-body" rows="16"
          placeholder="Write in Markdown. Headers, bold, links all work."></textarea>
      </div>

      <div class="bc-extra-fields">
        <div class="bc-extra" data-for="reflection" style="display:none;flex-direction:column;gap:0.3rem;">
          <label class="bc-label" for="bc-pull-quote">Pull quote (optional)</label>
          <input class="bc-input" id="bc-pull-quote" type="text" placeholder="One sentence to highlight" />
        </div>
        <div class="bc-extra" data-for="breakthrough" style="display:none;flex-direction:column;gap:0.3rem;">
          <label class="bc-label" for="bc-statement">The breakthrough statement</label>
          <input class="bc-input" id="bc-statement" type="text" placeholder="The thing you realised" />
        </div>
        <div class="bc-extra" data-for="question" style="display:none;flex-direction:column;gap:0.3rem;">
          <label class="bc-label" for="bc-question">The question</label>
          <input class="bc-input" id="bc-question" type="text" placeholder="The question, stated directly" />
        </div>
        <div class="bc-extra" data-for="reference" style="display:none;flex-direction:column;gap:0.3rem;">
          <label class="bc-label" for="bc-ref-source">Source</label>
          <input class="bc-input" id="bc-ref-source" type="text" placeholder="Author / publication / title" />
          <label class="bc-label" for="bc-ref-url" style="margin-top:0.5rem;">URL (optional)</label>
          <input class="bc-input" id="bc-ref-url" type="url" placeholder="https://..." />
        </div>
      </div>
    </div>

    <!-- ACTIONS -->
    <div class="bc-section bc-actions-section">
      <div class="bc-actions">
        <button class="bc-btn bc-btn--save"   id="bc-save">Save draft</button>
        <button class="bc-btn bc-btn--export" id="bc-export">Export .mdx</button>
        <button class="bc-btn bc-btn--clear"  id="bc-clear">Clear</button>
      </div>
      <p class="bc-hint">
        <strong style="color:var(--text-muted)">Save draft</strong> — stored in browser localStorage.<br/>
        <strong style="color:var(--text-muted)">Export .mdx</strong> — downloads a file ready to drop into
        <code>src/content/blog/</code>. Set <code>draft: false</code> to publish.<br/>
        Autosaves every 900ms while you type.
      </p>
    </div>

    <!-- SAVED DRAFTS -->
    <div class="bc-section">
      <h2 class="bc-section-title">Saved Drafts</h2>
      <div class="bc-drafts-list" id="bc-drafts-list"></div>
    </div>

  </div>
</ZoneLayout>

