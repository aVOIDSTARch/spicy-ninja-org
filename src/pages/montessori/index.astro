---
import ZoneLayout from '../../layouts/ZoneLayout.astro'
import SceneForest from '../../components/scenes/SceneForest.astro'
---

<ZoneLayout zone="montessori" title="Montessori — spicyninja.org">
  <SceneForest slot="scene" />

  <div style="padding: 14vh 4rem 6rem; max-width: 820px;">
    <p class="eyebrow">experience track</p>
    <h1 class="hero-heading" style="margin-bottom:1rem;">Montessori</h1>
    <p style="font-family:var(--font-body); font-size:1.05rem; color:var(--text-secondary);
              max-width:560px; line-height:1.85; margin-top:1.5rem; margin-bottom:3rem;">
      An infinitely branching knowledge tree. Nodes unlock nodes. Follow curiosity rather
      than sequence. Roots lead to branches lead to Bespoke Journey Courses.
    </p>
    <div style="border:1px solid var(--border); border-left:3px solid #c8922a;
                padding:2rem; background:var(--bg-card);">
      <p style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.2em;
                 text-transform:uppercase; color:#c8922a; margin-bottom:0.6rem;">
        In development
      </p>
      <p style="font-family:var(--font-body); color:var(--text-muted); font-size:0.9rem; line-height:1.7;">
        The visual node map — with locked, available, and completed states — is the next
        major build phase. The tree structure and node content are being designed in parallel.
      </p>
    </div>
  </div>
</ZoneLayout>
