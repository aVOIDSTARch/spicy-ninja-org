---
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t-4 border-black bg-gray-light mt-16">
  <div class="max-w-[960px] mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-mono uppercase font-bold mb-4 text-sm">About Mind</h3>
        <p class="font-body text-sm text-gray-dark">
          A living collection of ideas, thoughts, and evolving concepts.
          Each project documents a journey of exploration.
        </p>
      </div>

      <div>
        <h3 class="font-mono uppercase font-bold mb-4 text-sm">Navigation</h3>
        <ul class="space-y-2">
          <li>
            <a href="/" class="font-mono text-sm hover:text-accent">
              All Ideas
            </a>
          </li>
          <li>
            <a href="/mind/tags" class="font-mono text-sm hover:text-accent">
              Browse Tags
            </a>
          </li>
          <li>
            <a href="/about" class="font-mono text-sm hover:text-accent">
              About
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-mono uppercase font-bold mb-4 text-sm">Connect</h3>
        <p class="font-mono text-xs text-gray-dark">
          Part of the He Carries Water ecosystem
        </p>
        <a
          href="https://hecarrieswater.com"
          class="font-mono text-sm text-accent hover:underline block mt-2"
        >
          hecarrieswater.com →
        </a>
      </div>
    </div>

    <div
      class="mt-8 pt-8 border-t-2 border-black text-center font-mono text-xs text-gray"
    >
      <p>&copy; {currentYear} Mind. All rights reserved.</p>
    </div>
  </div>
</footer>
