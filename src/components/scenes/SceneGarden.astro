---
// SceneGarden.astro — Journal zone
// Stone lantern, koi pond with ripples, pre-dawn fog, sparse pine
// Ninja seated at pond edge, still and reflective. Muted gossamer accent.
import ParallaxScene from './ParallaxScene.astro'
---
<ParallaxScene zone="journal">
  <svg slot="far" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Pre-dawn horizon — barely lighter than dark -->
    <rect x="0" y="400" width="1200" height="400" fill="var(--sil-far)"/>
    <!-- Pale dawn band low on horizon -->
    <rect x="0" y="560" width="1200" height="60" fill="var(--sil-window)" opacity="0.07"/>
    <!-- Distant mountain silhouette -->
    <ellipse cx="350"  cy="600" rx="400" ry="160" fill="var(--sil-far)"/>
    <ellipse cx="900"  cy="580" rx="380" ry="140" fill="var(--sil-far)"/>
    <!-- Far pines -->
    <g fill="var(--sil-far)">
      <polygon points="80,560 120,430 160,560"/>
      <polygon points="90,450 120,370 150,450"/>
      <polygon points="95,390 120,330 145,390"/>
      <polygon points="200,560 240,450 280,560"/>
      <polygon points="210,455 240,380 270,455"/>
      <polygon points="900,550 940,440 980,550"/>
      <polygon points="910,445 940,365 970,445"/>
      <polygon points="1050,560 1090,450 1130,560"/>
      <polygon points="1060,455 1090,375 1120,455"/>
    </g>
  </svg>

  <svg slot="mid" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Koi pond — oval -->
    <ellipse cx="600" cy="680" rx="380" ry="100" fill="var(--sil-mid)" opacity="0.7"/>
    <!-- Pond ripples (concentric ellipses) -->
    <g fill="none" stroke="var(--sil-far)" stroke-width="1" opacity="0.25">
      <ellipse cx="600" cy="680" rx="350" ry="88"/>
      <ellipse cx="600" cy="680" rx="300" ry="75"/>
      <ellipse cx="600" cy="680" rx="240" ry="60"/>
      <ellipse cx="600" cy="680" rx="175" ry="44"/>
      <ellipse cx="600" cy="680" rx="110" ry="28"/>
    </g>
    <!-- Koi fish silhouettes in pond -->
    <g fill="var(--sil-window)" opacity="0.2">
      <ellipse cx="540" cy="672" rx="28" ry="9" transform="rotate(20,540,672)"/>
      <ellipse cx="650" cy="688" rx="24" ry="8" transform="rotate(-15,650,688)"/>
      <ellipse cx="600" cy="660" rx="22" ry="7" transform="rotate(5,600,660)"/>
    </g>
    <!-- Stone lantern left of pond -->
    <g fill="var(--sil-mid)">
      <!-- Post -->
      <rect x="220" y="540" width="18" height="140"/>
      <!-- Cap -->
      <polygon points="200,540 256,540 228,516"/>
      <!-- House -->
      <rect x="208" y="556" width="40" height="35"/>
      <!-- Glow inside lantern -->
      <rect x="212" y="560" width="32" height="27" fill="var(--sil-window)" opacity="0.5"/>
      <!-- Fire-box base -->
      <rect x="204" y="590" width="48" height="10" rx="2"/>
      <!-- Middle column -->
      <rect x="222" y="598" width="14" height="30"/>
      <!-- Base stone -->
      <ellipse cx="229" cy="635" rx="32" ry="10"/>
      <ellipse cx="229" cy="680" rx="26" ry="8"/>
    </g>
    <!-- Stepping stones across pond -->
    <g fill="var(--sil-mid)">
      <ellipse cx="390" cy="680" rx="28" ry="12"/>
      <ellipse cx="470" cy="675" rx="24" ry="10"/>
      <ellipse cx="545" cy="672" rx="22" ry="9"/>
      <ellipse cx="660" cy="673" rx="24" ry="10"/>
      <ellipse cx="745" cy="677" rx="26" ry="11"/>
    </g>
    <!-- Fog bands -->
    <ellipse cx="600" cy="720" rx="580" ry="55" fill="var(--sil-far)" opacity="0.35"/>
    <ellipse cx="300" cy="700" rx="350" ry="35" fill="var(--sil-far)" opacity="0.2"/>
    <ellipse cx="950" cy="710" rx="300" ry="30" fill="var(--sil-far)" opacity="0.2"/>
  </svg>

  <svg slot="near" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Near pine at right edge -->
    <g fill="var(--sil-near)">
      <rect x="1060" y="300" width="16" height="500"/>
      <polygon points="1020,460 1068,300 1116,460"/>
      <polygon points="1025,400 1068,260 1111,400"/>
      <polygon points="1030,345 1068,225 1106,345"/>
    </g>
    <!-- Pond bank / mossy ground -->
    <rect x="0" y="740" width="1200" height="60" fill="var(--sil-near)" opacity="0.7"/>
    <!-- Rock cluster near pond -->
    <g fill="var(--sil-near)">
      <ellipse cx="860" cy="700" rx="40" ry="20"/>
      <ellipse cx="895" cy="695" rx="28" ry="16"/>
      <ellipse cx="840" cy="698" rx="24" ry="14"/>
    </g>
  </svg>

  <svg slot="fg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Ninja seated at pond edge — utterly still, looking into water -->
    <g fill="var(--sil-fg)" transform="translate(360, 570)">
      <!-- Head bowed slightly -->
      <circle cx="0" cy="0" r="21" transform="rotate(8)"/>
      <!-- No visible eye slit — face turned down -->
      <!-- Torso upright, meditative -->
      <ellipse cx="0" cy="40" rx="22" ry="28"/>
      <!-- Hands in lap, barely visible -->
      <ellipse cx="-10" cy="62" rx="16" ry="8" transform="rotate(-5,-10,62)"/>
      <!-- Cross-legged — very settled -->
      <ellipse cx="-28" cy="72" rx="26" ry="12" transform="rotate(10,-28,72)"/>
      <ellipse cx="28"  cy="72" rx="26" ry="12" transform="rotate(-10,28,72)"/>
      <!-- Cloak pooling around — wide at base -->
      <path d="M -30 30 Q -55 50 -60 85 Q -20 90 0 75 Q 20 90 60 85 Q 55 50 30 30 Z"
            opacity="0.6"/>
    </g>
  </svg>
</ParallaxScene>
