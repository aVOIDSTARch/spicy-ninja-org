---
// SceneVillage.astro — Blog zone
// Village street at night: paper doors glowing, festival banners, street lamps
// Ninja walking through crowd, incognito. Personal, alive, in motion.
import ParallaxScene from './ParallaxScene.astro'
---
<ParallaxScene zone="blog">
  <svg slot="far" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Village building backs — shops and homes -->
    <g fill="var(--sil-far)">
      <rect x="0"    y="320" width="160" height="480"/>
      <polygon points="-10,320 170,320 80,270"/>
      <rect x="170"  y="350" width="130" height="450"/>
      <polygon points="160,350 310,350 235,295"/>
      <rect x="310"  y="300" width="180" height="500"/>
      <polygon points="300,300 500,300 400,240"/>
      <polygon points="310,245 490,245 400,200"/>
      <rect x="500"  y="340" width="150" height="460"/>
      <polygon points="490,340 660,340 575,288"/>
      <rect x="660"  y="310" width="170" height="490"/>
      <polygon points="650,310 840,310 745,255"/>
      <rect x="840"  y="345" width="140" height="455"/>
      <polygon points="830,345 990,345 910,293"/>
      <rect x="990"  y="320" width="160" height="480"/>
      <polygon points="980,320 1160,320 1070,268"/>
      <rect x="1150" y="355" width="60"  height="445"/>
    </g>
    <!-- Glowing shop windows -->
    <g fill="var(--sil-window)" opacity="0.25">
      <rect x="20"  y="350" width="50" height="40"/>
      <rect x="80"  y="350" width="50" height="40"/>
      <rect x="20"  y="420" width="50" height="40"/>
      <rect x="80"  y="420" width="50" height="40"/>
      <rect x="185" y="375" width="45" height="38"/>
      <rect x="240" y="375" width="45" height="38"/>
      <rect x="330" y="325" width="55" height="45"/>
      <rect x="400" y="325" width="55" height="45"/>
      <rect x="330" y="395" width="55" height="45"/>
      <rect x="400" y="395" width="55" height="45"/>
      <rect x="515" y="365" width="50" height="40"/>
      <rect x="575" y="365" width="50" height="40"/>
      <rect x="670" y="335" width="55" height="45"/>
      <rect x="735" y="335" width="55" height="45"/>
      <rect x="855" y="368" width="48" height="40"/>
      <rect x="912" y="368" width="48" height="40"/>
      <rect x="1005" y="345" width="52" height="42"/>
      <rect x="1068" y="345" width="52" height="42"/>
    </g>
    <!-- Hanging sign boards -->
    <g fill="var(--sil-far)">
      <rect x="60"  y="268" width="40" height="28" rx="2"/>
      <line x1="80"  y1="240" x2="80"  y2="270" stroke="var(--sil-far)" stroke-width="2"/>
      <rect x="360" y="238" width="40" height="28" rx="2"/>
      <line x1="380" y1="210" x2="380" y2="240" stroke="var(--sil-far)" stroke-width="2"/>
      <rect x="700" y="253" width="40" height="28" rx="2"/>
      <line x1="720" y1="225" x2="720" y2="255" stroke="var(--sil-far)" stroke-width="2"/>
      <rect x="1020" y="265" width="40" height="28" rx="2"/>
      <line x1="1040" y1="237" x2="1040" y2="267" stroke="var(--sil-far)" stroke-width="2"/>
    </g>
  </svg>

  <svg slot="mid" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Festival banners strung across street -->
    <line x1="0"   y1="360" x2="400"  y2="340" stroke="var(--sil-mid)" stroke-width="2" opacity="0.6"/>
    <line x1="400" y1="340" x2="800"  y2="355" stroke="var(--sil-mid)" stroke-width="2" opacity="0.6"/>
    <line x1="800" y1="355" x2="1200" y2="338" stroke="var(--sil-mid)" stroke-width="2" opacity="0.6"/>
    <!-- Banner flags hanging from cord -->
    <g fill="var(--sil-mid)">
      <rect x="50"  y="358" width="20" height="40" rx="2"/>
      <rect x="120" y="352" width="20" height="40" rx="2"/>
      <rect x="190" y="348" width="20" height="40" rx="2"/>
      <rect x="260" y="344" width="20" height="40" rx="2"/>
      <rect x="330" y="340" width="20" height="40" rx="2"/>
      <rect x="430" y="340" width="20" height="40" rx="2"/>
      <rect x="510" y="343" width="20" height="40" rx="2"/>
      <rect x="590" y="346" width="20" height="40" rx="2"/>
      <rect x="670" y="349" width="20" height="40" rx="2"/>
      <rect x="750" y="352" width="20" height="40" rx="2"/>
      <rect x="840" y="354" width="20" height="40" rx="2"/>
      <rect x="920" y="350" width="20" height="40" rx="2"/>
      <rect x="1000" y="346" width="20" height="40" rx="2"/>
      <rect x="1080" y="342" width="20" height="40" rx="2"/>
      <rect x="1150" y="339" width="20" height="40" rx="2"/>
    </g>
    <!-- Street lanterns on poles -->
    <g fill="var(--sil-mid)">
      <rect x="148" y="480" width="8" height="250"/>
      <ellipse cx="152" cy="478" rx="14" ry="20" fill="var(--sil-window)" opacity="0.55"/>
      <rect x="144" y="458" width="16" height="7" rx="2" fill="var(--sil-mid)"/>
      <rect x="144" y="493" width="16" height="7" rx="2" fill="var(--sil-mid)"/>
      <rect x="498" y="475" width="8" height="255"/>
      <ellipse cx="502" cy="473" rx="14" ry="20" fill="var(--sil-window)" opacity="0.5"/>
      <rect x="494" y="453" width="16" height="7" rx="2" fill="var(--sil-mid)"/>
      <rect x="494" y="488" width="16" height="7" rx="2" fill="var(--sil-mid)"/>
      <rect x="898" y="480" width="8" height="250"/>
      <ellipse cx="902" cy="478" rx="14" ry="20" fill="var(--sil-window)" opacity="0.52"/>
      <rect x="894" y="458" width="16" height="7" rx="2" fill="var(--sil-mid)"/>
      <rect x="894" y="493" width="16" height="7" rx="2" fill="var(--sil-mid)"/>
    </g>
    <!-- Crowd silhouettes — varied heights, incognito figures -->
    <g fill="var(--sil-mid)" opacity="0.6">
      <circle cx="250" cy="570" r="18"/><rect x="235" y="585" width="30" height="80" rx="4"/>
      <circle cx="310" cy="580" r="15"/><rect x="298" y="592" width="25" height="72" rx="4"/>
      <circle cx="680" cy="565" r="20"/><rect x="663" y="582" width="34" height="88" rx="4"/>
      <circle cx="750" cy="575" r="16"/><rect x="737" y="588" width="27" height="76" rx="4"/>
      <circle cx="810" cy="568" r="19"/><rect x="794" y="584" width="32" height="82" rx="4"/>
      <circle cx="1050" cy="572" r="17"/><rect x="1036" y="586" width="28" height="78" rx="4"/>
    </g>
  </svg>

  <svg slot="near" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Street surface -->
    <rect x="0" y="680" width="1200" height="120" fill="var(--sil-near)" opacity="0.7"/>
    <!-- Cobblestone pattern -->
    <g stroke="var(--sil-far)" stroke-width="1" fill="none" opacity="0.15">
      <line x1="0" y1="700" x2="1200" y2="700"/>
      <line x1="0" y1="725" x2="1200" y2="725"/>
      <line x1="0" y1="750" x2="1200" y2="750"/>
      <line x1="60"  y1="680" x2="60"  y2="800"/>
      <line x1="130" y1="680" x2="130" y2="800"/>
      <line x1="200" y1="680" x2="200" y2="800"/>
      <line x1="280" y1="680" x2="280" y2="800"/>
      <line x1="360" y1="680" x2="360" y2="800"/>
      <line x1="440" y1="680" x2="440" y2="800"/>
      <line x1="520" y1="680" x2="520" y2="800"/>
      <line x1="600" y1="680" x2="600" y2="800"/>
      <line x1="680" y1="680" x2="680" y2="800"/>
      <line x1="760" y1="680" x2="760" y2="800"/>
      <line x1="840" y1="680" x2="840" y2="800"/>
      <line x1="920" y1="680" x2="920" y2="800"/>
      <line x1="1000" y1="680" x2="1000" y2="800"/>
      <line x1="1080" y1="680" x2="1080" y2="800"/>
      <line x1="1150" y1="680" x2="1150" y2="800"/>
    </g>
  </svg>

  <svg slot="fg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Ninja walking incognito — ordinary pace, hood up, blending in -->
    <g fill="var(--sil-fg)" transform="translate(470, 490)">
      <circle cx="0" cy="0" r="22"/>
      <!-- Hood over head — wide wrap -->
      <ellipse cx="0" cy="-8" rx="28" ry="20" opacity="0.7"/>
      <!-- Only eyes visible — narrow slit -->
      <rect x="-10" y="-2" width="20" height="6" rx="3"
            fill="var(--zone-accent, var(--cinnabar))"/>
      <!-- Torso in walking pose — slight lean -->
      <ellipse cx="4" cy="42" rx="22" ry="30" transform="rotate(5,4,42)"/>
      <!-- Arms in natural swing — not ninja-pose -->
      <ellipse cx="-18" cy="35" rx="8" ry="24" transform="rotate(15,-18,35)"/>
      <ellipse cx="24"  cy="38" rx="8" ry="22" transform="rotate(-12,24,38)"/>
      <!-- Mid-stride legs -->
      <ellipse cx="-12" cy="84" rx="10" ry="30" transform="rotate(12,-12,84)"/>
      <ellipse cx="-16" cy="118" rx="8" ry="22" transform="rotate(8,-16,118)"/>
      <ellipse cx="16"  cy="80" rx="10" ry="28" transform="rotate(-15,16,80)"/>
      <ellipse cx="20"  cy="112" rx="8" ry="20" transform="rotate(-10,20,112)"/>
      <!-- Long outer robe hem -->
      <path d="M -24 65 Q -30 100 -28 140 Q 0 145 28 140 Q 30 100 24 65 Z" opacity="0.5"/>
    </g>
  </svg>
</ParallaxScene>
