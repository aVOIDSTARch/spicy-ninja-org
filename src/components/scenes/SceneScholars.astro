---
// SceneScholars.astro — Fundamentals zone
// Scholar's room: scrolls, ink stone, candlelit desk visible through window
// Ninja seated cross-legged reading a scroll. Copper/ink scholarly tone.
import ParallaxScene from './ParallaxScene.astro'
---
<ParallaxScene zone="fundamentals">
  <svg slot="far" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Wall with rice paper panels — warm candlelight glow -->
    <rect x="0" y="280" width="1200" height="520" fill="var(--sil-far)"/>
    <!-- Large shoji wall -->
    <rect x="0" y="288" width="1200" height="20" fill="var(--sil-far)"/>
    <!-- Warm glow panels — scholar's candlelight -->
    <rect x="40"  y="310" width="200" height="300" fill="var(--sil-window)" opacity="0.20"/>
    <rect x="260" y="310" width="200" height="300" fill="var(--sil-window)" opacity="0.16"/>
    <rect x="500" y="310" width="200" height="300" fill="var(--sil-window)" opacity="0.22"/>
    <rect x="720" y="310" width="200" height="300" fill="var(--sil-window)" opacity="0.14"/>
    <rect x="940" y="310" width="220" height="300" fill="var(--sil-window)" opacity="0.19"/>
    <!-- Panel frames -->
    <g fill="none" stroke="var(--sil-far)" stroke-width="3" opacity="0.7">
      <rect x="40"  y="310" width="200" height="300"/>
      <line x1="140" y1="310" x2="140" y2="610"/>
      <line x1="40"  y1="460" x2="240" y2="460"/>
      <rect x="260" y="310" width="200" height="300"/>
      <line x1="360" y1="310" x2="360" y2="610"/>
      <line x1="260" y1="460" x2="460" y2="460"/>
      <rect x="500" y="310" width="200" height="300"/>
      <line x1="600" y1="310" x2="600" y2="610"/>
      <line x1="500" y1="460" x2="700" y2="460"/>
      <rect x="720" y="310" width="200" height="300"/>
      <line x1="820" y1="310" x2="820" y2="610"/>
      <line x1="720" y1="460" x2="920" y2="460"/>
      <rect x="940" y="310" width="220" height="300"/>
      <line x1="1050" y1="310" x2="1050" y2="610"/>
      <line x1="940"  y1="460" x2="1160" y2="460"/>
    </g>
    <!-- Ceiling -->
    <rect x="0" y="275" width="1200" height="18" fill="var(--sil-far)"/>
    <!-- Shadow silhouette of scholar visible in brightest panel -->
    <g fill="var(--sil-far)" opacity="0.35" transform="translate(530, 360)">
      <circle cx="70" cy="0" r="18"/>
      <ellipse cx="70" cy="38" rx="24" ry="20"/>
      <rect x="30" y="50" width="80" height="8" rx="2"/>
    </g>
  </svg>

  <svg slot="mid" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Scroll rack on left wall -->
    <g fill="var(--sil-mid)">
      <rect x="30" y="350" width="12" height="320"/>
      <rect x="110" y="350" width="12" height="320"/>
      <rect x="24" y="365" width="105" height="8" rx="2"/>
      <rect x="24" y="440" width="105" height="8" rx="2"/>
      <rect x="24" y="515" width="105" height="8" rx="2"/>
      <!-- Scrolls on rack -->
      <rect x="38" y="340" width="18" height="100" rx="6"/>
      <rect x="62" y="345" width="16" height="95"  rx="6"/>
      <rect x="84" y="338" width="18" height="105" rx="6"/>
      <rect x="38" y="415" width="18" height="90"  rx="6"/>
      <rect x="62" y="420" width="16" height="85"  rx="6"/>
      <rect x="84" y="413" width="18" height="95"  rx="6"/>
    </g>
    <!-- Hanging scrolls from ceiling center -->
    <g fill="var(--sil-mid)">
      <rect x="540" y="295" width="22" height="180" rx="3"/>
      <rect x="535" y="292" width="32" height="10" rx="3"/>
      <rect x="535" y="470" width="32" height="10" rx="3"/>
      <rect x="760" y="295" width="22" height="200" rx="3"/>
      <rect x="755" y="292" width="32" height="10" rx="3"/>
      <rect x="755" y="490" width="32" height="10" rx="3"/>
    </g>
    <!-- Low writing desk -->
    <g fill="var(--sil-mid)">
      <rect x="380" y="600" width="440" height="20" rx="4"/>
      <rect x="390" y="618" width="16" height="80"/>
      <rect x="796" y="618" width="16" height="80"/>
      <!-- Ink stone on desk -->
      <ellipse cx="500" cy="598" rx="35" ry="12" rx2="3"/>
      <!-- Brush holder -->
      <rect x="580" y="565" width="12" height="36" rx="4"/>
      <ellipse cx="586" cy="562" rx="18" ry="8"/>
      <!-- Open book/scroll on desk -->
      <rect x="620" y="578" width="120" height="24" rx="2"/>
      <line x1="680" y1="578" x2="680" y2="602" stroke="var(--sil-far)" stroke-width="1.5"/>
    </g>
    <!-- Candle on desk -->
    <g>
      <rect x="752" y="570" width="8" height="30" fill="var(--sil-mid)"/>
      <rect x="748" y="596" width="16" height="6" rx="1" fill="var(--sil-mid)"/>
      <ellipse cx="756" cy="568" rx="6" ry="10" fill="var(--sil-window)" opacity="0.7"/>
    </g>
  </svg>

  <svg slot="near" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Floor mats -->
    <rect x="0" y="680" width="1200" height="120" fill="var(--sil-near)" opacity="0.6"/>
    <g stroke="var(--sil-far)" stroke-width="1.5" fill="none" opacity="0.25">
      <line x1="0" y1="690" x2="1200" y2="690"/>
      <line x1="0" y1="720" x2="1200" y2="720"/>
      <line x1="200" y1="680" x2="200" y2="720"/>
      <line x1="400" y1="680" x2="400" y2="720"/>
      <line x1="600" y1="680" x2="600" y2="720"/>
      <line x1="800" y1="680" x2="800" y2="720"/>
      <line x1="1000" y1="680" x2="1000" y2="720"/>
    </g>
    <!-- Near pillars -->
    <rect x="0"    y="350" width="36" height="450" fill="var(--sil-near)" opacity="0.9"/>
    <rect x="1164" y="350" width="36" height="450" fill="var(--sil-near)" opacity="0.9"/>
  </svg>

  <svg slot="fg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Ninja seated cross-legged reading a scroll -->
    <g fill="var(--sil-fg)" transform="translate(750, 480)">
      <!-- Head tilted down reading -->
      <circle cx="0" cy="0" r="22" transform="rotate(12)"/>
      <rect x="-13" y="-3" width="26" height="8" rx="3"
            fill="var(--zone-accent, var(--cinnabar))" opacity="0.8"/>
      <!-- Torso leaning forward -->
      <ellipse cx="2" cy="42" rx="24" ry="28" transform="rotate(10,2,42)"/>
      <!-- Arms holding scroll open -->
      <ellipse cx="-28" cy="28" rx="9" ry="22" transform="rotate(50,-28,28)"/>
      <ellipse cx="30"  cy="26" rx="9" ry="22" transform="rotate(-48,30,26)"/>
      <!-- Scroll unrolled between hands -->
      <rect x="-48" y="14" width="96" height="18" rx="6" fill="var(--sil-mid)" opacity="0.9"/>
      <line x1="-36" y1="14" x2="-36" y2="32" stroke="var(--sil-far)" stroke-width="1" opacity="0.4"/>
      <line x1="-18" y1="14" x2="-18" y2="32" stroke="var(--sil-far)" stroke-width="1" opacity="0.4"/>
      <line x1="0"   y1="14" x2="0"   y2="32" stroke="var(--sil-far)" stroke-width="1" opacity="0.4"/>
      <line x1="18"  y1="14" x2="18"  y2="32" stroke="var(--sil-far)" stroke-width="1" opacity="0.4"/>
      <line x1="36"  y1="14" x2="36"  y2="32" stroke="var(--sil-far)" stroke-width="1" opacity="0.4"/>
      <!-- Cross-legged legs -->
      <ellipse cx="-24" cy="70" rx="22" ry="14" transform="rotate(15,-24,70)"/>
      <ellipse cx="24"  cy="70" rx="22" ry="14" transform="rotate(-15,24,70)"/>
    </g>
  </svg>
</ParallaxScene>
