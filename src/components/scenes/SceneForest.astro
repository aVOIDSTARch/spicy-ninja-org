---
// SceneForest.astro — Montessori Track
// Bamboo grove at dusk, lanterns strung between trunks, path disappearing into darkness
// Ninja crouched in branches, observing. Amber/saffron accent zone.
import ParallaxScene from './ParallaxScene.astro'
---
<ParallaxScene zone="montessori">
  <svg slot="far" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Sky gradient suggestion -->
    <rect x="0" y="0" width="1200" height="800" fill="var(--sil-far)" opacity="0.4"/>
    <!-- Distant moon -->
    <circle cx="900" cy="80" r="52" fill="var(--sil-far)"/>
    <circle cx="900" cy="80" r="44" fill="var(--sil-window)" opacity="0.2"/>
    <!-- Far tree silhouettes — very thin, distant -->
    <rect x="80"  y="200" width="6"  height="600" fill="var(--sil-far)"/>
    <rect x="200" y="180" width="7"  height="620" fill="var(--sil-far)"/>
    <rect x="340" y="160" width="6"  height="640" fill="var(--sil-far)"/>
    <rect x="480" y="190" width="7"  height="610" fill="var(--sil-far)"/>
    <rect x="620" y="170" width="6"  height="630" fill="var(--sil-far)"/>
    <rect x="760" y="185" width="7"  height="615" fill="var(--sil-far)"/>
    <rect x="950" y="175" width="6"  height="625" fill="var(--sil-far)"/>
    <rect x="1100" y="200" width="7" height="600" fill="var(--sil-far)"/>
    <!-- Bamboo nodes on far trees -->
    <g fill="var(--sil-mid)" opacity="0.3">
      <rect x="77"  y="280" width="12" height="5" rx="2"/>
      <rect x="77"  y="380" width="12" height="5" rx="2"/>
      <rect x="77"  y="480" width="12" height="5" rx="2"/>
      <rect x="197" y="260" width="13" height="5" rx="2"/>
      <rect x="197" y="360" width="13" height="5" rx="2"/>
      <rect x="197" y="460" width="13" height="5" rx="2"/>
    </g>
  </svg>

  <svg slot="mid" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Mid bamboo grove — thicker, with leaves -->
    <g fill="var(--sil-mid)">
      <rect x="50"  y="100" width="12" height="700"/>
      <rect x="47"  y="108" width="18" height="7" rx="3"/>
      <rect x="47"  y="218" width="18" height="7" rx="3"/>
      <rect x="47"  y="328" width="18" height="7" rx="3"/>
      <rect x="47"  y="438" width="18" height="7" rx="3"/>
      <rect x="47"  y="548" width="18" height="7" rx="3"/>
      <!-- Leaves -->
      <ellipse cx="38"  cy="102" rx="22" ry="8" transform="rotate(-25,38,102)"/>
      <ellipse cx="68"  cy="105" rx="20" ry="7" transform="rotate(20,68,105)"/>

      <rect x="180" y="80"  width="14" height="720"/>
      <rect x="177" y="90"  width="20" height="7" rx="3"/>
      <rect x="177" y="210" width="20" height="7" rx="3"/>
      <rect x="177" y="330" width="20" height="7" rx="3"/>
      <rect x="177" y="450" width="20" height="7" rx="3"/>
      <ellipse cx="168" cy="82" rx="24" ry="9" transform="rotate(-20,168,82)"/>
      <ellipse cx="200" cy="84" rx="22" ry="8" transform="rotate(18,200,84)"/>

      <rect x="420" y="90"  width="13" height="710"/>
      <rect x="417" y="100" width="19" height="7" rx="3"/>
      <rect x="417" y="220" width="19" height="7" rx="3"/>
      <rect x="417" y="340" width="19" height="7" rx="3"/>
      <ellipse cx="410" cy="91" rx="22" ry="8" transform="rotate(-22,410,91)"/>
      <ellipse cx="438" cy="93" rx="20" ry="7" transform="rotate(16,438,93)"/>

      <rect x="700" y="70"  width="14" height="730"/>
      <rect x="697" y="80"  width="20" height="7" rx="3"/>
      <rect x="697" y="200" width="20" height="7" rx="3"/>
      <rect x="697" y="320" width="20" height="7" rx="3"/>
      <rect x="697" y="440" width="20" height="7" rx="3"/>
      <ellipse cx="690" cy="72" rx="24" ry="9" transform="rotate(-18,690,72)"/>
      <ellipse cx="718" cy="74" rx="22" ry="8" transform="rotate(20,718,74)"/>

      <rect x="980" y="85"  width="13" height="715"/>
      <rect x="977" y="95"  width="19" height="7" rx="3"/>
      <rect x="977" y="215" width="19" height="7" rx="3"/>
      <rect x="977" y="335" width="19" height="7" rx="3"/>
      <ellipse cx="970" cy="86" rx="22" ry="8" transform="rotate(-21,970,86)"/>
      <ellipse cx="998" cy="88" rx="20" ry="7" transform="rotate(17,998,88)"/>
    </g>

    <!-- Strung lanterns between trees -->
    <!-- Cord lines -->
    <line x1="56"  y1="320" x2="186" y2="340" stroke="var(--sil-mid)" stroke-width="1.5" opacity="0.6"/>
    <line x1="186" y1="340" x2="426" y2="320" stroke="var(--sil-mid)" stroke-width="1.5" opacity="0.6"/>
    <line x1="426" y1="320" x2="706" y2="310" stroke="var(--sil-mid)" stroke-width="1.5" opacity="0.6"/>
    <line x1="706" y1="310" x2="986" y2="325" stroke="var(--sil-mid)" stroke-width="1.5" opacity="0.6"/>
    <!-- Lantern bodies on the cords -->
    <g>
      <ellipse cx="120" cy="332" rx="12" ry="16" fill="var(--sil-window)" opacity="0.5"/>
      <rect x="112" y="316" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <rect x="112" y="344" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <ellipse cx="305" cy="330" rx="12" ry="16" fill="var(--sil-window)" opacity="0.45"/>
      <rect x="297" y="314" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <rect x="297" y="342" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <ellipse cx="565" cy="315" rx="12" ry="16" fill="var(--sil-window)" opacity="0.5"/>
      <rect x="557" y="299" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <rect x="557" y="327" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <ellipse cx="845" cy="318" rx="12" ry="16" fill="var(--sil-window)" opacity="0.45"/>
      <rect x="837" y="302" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
      <rect x="837" y="330" width="16" height="5" rx="2" fill="var(--sil-mid)"/>
    </g>

    <!-- Path disappearing into darkness -->
    <ellipse cx="600" cy="800" rx="140" ry="60" fill="var(--sil-mid)" opacity="0.3"/>
    <ellipse cx="600" cy="780" rx="80" ry="30" fill="var(--sil-far)" opacity="0.4"/>
  </svg>

  <svg slot="near" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Near thick bamboo trunks -->
    <g fill="var(--sil-near)" opacity="0.8">
      <rect x="0"    y="0" width="18" height="800"/>
      <rect x="0"    y="0" width="28" height="12" rx="4"/>
      <rect x="0"    y="120" width="28" height="12" rx="4"/>
      <rect x="0"    y="240" width="28" height="12" rx="4"/>
      <rect x="0"    y="360" width="28" height="12" rx="4"/>
      <rect x="0"    y="480" width="28" height="12" rx="4"/>
      <rect x="1182" y="0" width="18" height="800"/>
      <rect x="1172" y="0" width="28" height="12" rx="4"/>
      <rect x="1172" y="130" width="28" height="12" rx="4"/>
      <rect x="1172" y="260" width="28" height="12" rx="4"/>
      <rect x="1172" y="390" width="28" height="12" rx="4"/>
    </g>
    <!-- Ground undergrowth -->
    <rect x="0" y="720" width="1200" height="80" fill="var(--sil-near)" opacity="0.5"/>
    <!-- Ground mist -->
    <ellipse cx="300" cy="730" rx="280" ry="35" fill="var(--sil-mid)" opacity="0.2"/>
    <ellipse cx="900" cy="725" rx="300" ry="30" fill="var(--sil-mid)" opacity="0.18"/>
  </svg>

  <svg slot="fg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMax meet"
       style="position:absolute;bottom:0;left:0;width:100%;height:100%">
    <!-- Ninja crouched in tree branches, observing downward -->
    <g fill="var(--sil-fg)" transform="translate(680, 180)">
      <!-- Branch they're sitting on -->
      <rect x="-80" y="60" width="200" height="10" rx="4" fill="var(--sil-mid)" opacity="0.9"/>
      <!-- Body — crouched low -->
      <ellipse cx="20" cy="40" rx="22" ry="18" transform="rotate(-15,20,40)"/>
      <!-- Head looking down -->
      <circle cx="10" cy="12" r="18"/>
      <rect x="-2" y="8" width="24" height="7" rx="3" fill="var(--zone-accent, var(--cinnabar-warm))"/>
      <!-- Arm gripping branch -->
      <ellipse cx="-18" cy="52" rx="8" ry="20" transform="rotate(70,-18,52)"/>
      <!-- Leg tucked -->
      <ellipse cx="10"  cy="62" rx="10" ry="22" transform="rotate(-25,10,62)"/>
      <ellipse cx="30"  cy="58" rx="10" ry="20" transform="rotate(10,30,58)"/>
      <!-- Cloak trailing -->
      <path d="M 30 30 Q 60 50 70 80 Q 50 70 25 55 Z" opacity="0.7"/>
    </g>
  </svg>
</ParallaxScene>
