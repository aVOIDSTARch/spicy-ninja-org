
<style>
/* ── NOTES PANEL ── */
.notes-panel {
  position: fixed;
  top: 0;
  right: 0;
  width: min(420px, 100vw);
  height: 100vh;
  background: var(--bg-secondary);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  z-index: 200;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
}
.notes-panel[aria-hidden="false"] { transform: translateX(0); }

.notes-panel__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 1.2rem 1.5rem 1rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.notes-panel__eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.5rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--text-ghost);
  margin-bottom: 0.3rem;
}
.notes-panel__title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--text-primary);
}
.notes-panel__close {
  background: none;
  border: none;
  color: var(--text-ghost);
  cursor: pointer;
  font-size: 0.9rem;
  padding: 0.2rem 0.4rem;
  transition: color 0.15s;
}
.notes-panel__close:hover { color: var(--text-primary); }

.notes-panel__sessions {
  flex: 0 0 auto;
  max-height: 200px;
  overflow-y: auto;
  padding: 0.8rem 1.5rem;
  border-bottom: 1px solid var(--border);
  scrollbar-width: thin;
}
.notes-session-entry {
  margin-bottom: 1rem;
}
.notes-session-entry__date {
  font-family: var(--font-mono);
  font-size: 0.52rem;
  color: var(--text-ghost);
  letter-spacing: 0.15em;
  margin-bottom: 0.3rem;
}
.notes-session-entry__text {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.notes-panel__compose {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 1rem 1.5rem 1.5rem;
  min-height: 0;
}
.notes-panel__session-label {
  font-family: var(--font-mono);
  font-size: 0.52rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--cinnabar);
  margin-bottom: 0.6rem;
}
.notes-panel__textarea {
  flex: 1;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 0.75rem;
  line-height: 1.65;
  padding: 0.9rem 1rem;
  resize: none;
  outline: none;
  min-height: 0;
  transition: border-color 0.2s;
}
.notes-panel__textarea:focus { border-color: var(--border-hi); }

.notes-panel__actions {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.8rem;
}
.notes-panel__btn {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.45rem 1rem;
  border: 1px solid var(--border);
  background: none;
  color: var(--text-muted);
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.notes-panel__btn:hover,
.notes-panel__btn--save:hover { border-color: var(--cinnabar); color: var(--cinnabar); }
.notes-panel__btn--export:hover { border-color: var(--gossamer); color: var(--gossamer); }

.notes-panel__hint {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  color: var(--text-ghost);
  margin-top: 0.6rem;
  line-height: 1.5;
}
.notes-panel__hint code {
  color: var(--text-muted);
  background: var(--bg-raised);
  padding: 0.1em 0.3em;
}

/* ── TRIGGER BUTTON ── */
.notes-trigger {
  position: fixed;
  bottom: 2rem;
  left: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  color: var(--text-ghost);
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.5rem 0.9rem;
  cursor: pointer;
  z-index: 100;
  transition: border-color 0.2s, color 0.2s;
}
.notes-trigger:hover { border-color: var(--cinnabar); color: var(--cinnabar); }
.notes-trigger__icon { font-size: 0.85rem; line-height: 1; }

/* ── BACKDROP ── */
.notes-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 199;
}
.notes-backdrop.active { display: block; }
</style>

<script define:vars={{ slug }}>
const STORAGE_KEY = `sn-notes:${slug}`;
const TODAY = new Date().toISOString().slice(0, 10);
const SESSION_KEY = `${STORAGE_KEY}:${TODAY}`;

const panel     = document.getElementById('notes-panel');
const backdrop  = document.getElementById('notes-backdrop');
const trigger   = document.getElementById('notes-trigger');
const closeBtn  = document.getElementById('notes-close');
const textarea  = document.getElementById('notes-textarea');
const saveBtn   = document.getElementById('notes-save');
const exportBtn = document.getElementById('notes-export');
const sessionsEl = document.getElementById('notes-sessions');
const labelEl    = document.getElementById('notes-session-label');

// ── Helpers ──────────────────────────────────────────────────
function getAllSessions() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : {};
  } catch { return {}; }
}
function saveSession(text) {
  const all = getAllSessions();
  all[TODAY] = text;
  localStorage.setItem(STORAGE_KEY, JSON.stringify(all));
}
function renderPreviousSessions() {
  const all = getAllSessions();
  const past = Object.entries(all)
    .filter(([d]) => d !== TODAY)
    .sort(([a], [b]) => b.localeCompare(a));
  if (past.length === 0) {
    sessionsEl.innerHTML = '<p style="font-family:var(--font-mono);font-size:0.58rem;color:var(--text-ghost);padding:0.3rem 0">No previous sessions</p>';
    return;
  }
  sessionsEl.innerHTML = past.map(([date, text]) => `
    <div class="notes-session-entry">
      <div class="notes-session-entry__date">${date}</div>
      <div class="notes-session-entry__text">${text.slice(0,200)}${text.length > 200 ? '…' : ''}</div>
    </div>
  `).join('');
}

// ── Open / Close ─────────────────────────────────────────────
function openPanel() {
  panel.setAttribute('aria-hidden', 'false');
  backdrop.classList.add('active');
  trigger.setAttribute('aria-expanded', 'true');
  labelEl.textContent = `Session — ${TODAY}`;
  textarea.value = getAllSessions()[TODAY] ?? '';
  renderPreviousSessions();
  setTimeout(() => textarea.focus(), 350);
}
function closePanel() {
  panel.setAttribute('aria-hidden', 'true');
  backdrop.classList.remove('active');
  trigger.setAttribute('aria-expanded', 'false');
}

trigger?.addEventListener('click', openPanel);
closeBtn?.addEventListener('click', closePanel);
backdrop?.addEventListener('click', closePanel);

// ── Autosave on keystroke ─────────────────────────────────────
textarea?.addEventListener('input', () => saveSession(textarea.value));

// ── Manual save ──────────────────────────────────────────────
saveBtn?.addEventListener('click', () => {
  saveSession(textarea.value);
  saveBtn.textContent = 'Saved ✓';
  setTimeout(() => { saveBtn.textContent = 'Save'; }, 1500);
});

// ── Export ───────────────────────────────────────────────────
exportBtn?.addEventListener('click', () => {
  const all = getAllSessions();
  const entries = Object.entries(all).sort(([a], [b]) => b.localeCompare(a));
  if (entries.length === 0) { alert('No notes to export.'); return; }

  const header = `<!-- append this block to notes/${slug}.md -->\n\n`;
  const body = entries.map(([date, text]) =>
    `---\n\n## ${date}\n\n${text.trim()}\n`
  ).join('\n');

  const blob = new Blob([header + body], { type: 'text/markdown' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `notes-${slug}-${TODAY}.md`;
  a.click();
  URL.revokeObjectURL(url);
});

// ── Keyboard close ────────────────────────────────────────────
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && panel.getAttribute('aria-hidden') === 'false') closePanel();
});
</script>
