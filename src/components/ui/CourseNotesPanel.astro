---
/**
 * CourseNotesPanel.astro
 * Slide-out right panel for per-course notes.
 * Usage: <CourseNotesPanel slug={slug} courseTitle={title} />
 * Wire a trigger button on the page with id="notes-trigger"
 * OR this component renders its own floating trigger.
 */
interface Props {
  slug: string
  courseTitle?: string
}
const { slug, courseTitle = 'Course' } = Astro.props
---

<!-- Trigger button (floating, bottom-left of content area) -->
<button class="notes-trigger" id="notes-trigger" aria-expanded="false" aria-controls="notes-panel">
  <span class="notes-trigger__icon">✎</span>
  <span>Notes</span>
</button>

<!-- Backdrop -->
<div class="notes-backdrop" id="notes-backdrop" aria-hidden="true"></div>

<!-- Panel -->
<aside class="notes-panel" id="notes-panel" aria-hidden="true" aria-label="Course notes">
  <div class="notes-panel__header">
    <div>
      <span class="notes-panel__eyebrow">Course Notes</span>
      <span class="notes-panel__title">{courseTitle}</span>
    </div>
    <button class="notes-panel__close" id="notes-close" aria-label="Close notes">✕</button>
  </div>

  <!-- Previous sessions -->
  <div class="notes-panel__sessions" id="notes-sessions" aria-label="Previous sessions"></div>

  <!-- Current session compose -->
  <div class="notes-panel__compose">
    <div class="notes-panel__session-label" id="notes-session-label">Today</div>
    <textarea
      class="notes-panel__textarea"
      id="notes-textarea"
      placeholder="Notes for this session. Markdown supported. Autosaves as you type."
      rows="12"
    ></textarea>
    <div class="notes-panel__actions">
      <button class="notes-panel__btn notes-panel__btn--save"   id="notes-save">Save</button>
      <button class="notes-panel__btn notes-panel__btn--export" id="notes-export">Export .md</button>
    </div>
    <p class="notes-panel__hint">
      Autosaves to browser storage keyed to this course.<br/>
      Export downloads all sessions as a single <code>.md</code> file.
    </p>
  </div>
</aside>

<style>
/* ── NOTES PANEL ── */
.notes-panel {
  position: fixed;
  top: 0; right: 0;
  width: min(420px, 100vw);
  height: 100vh;
  background: var(--bg-secondary);
  border-left: 1px solid var(--border);
  border-top: 2px solid var(--cinnabar);
  display: flex;
  flex-direction: column;
  z-index: 500;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
}
.notes-panel[aria-hidden="false"] { transform: translateX(0); }

.notes-panel__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 1.2rem 1.5rem 1rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.notes-panel__eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.5rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--cinnabar);
  margin-bottom: 0.3rem;
}
.notes-panel__title {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--text-primary);
  line-height: 1.2;
}
.notes-panel__close {
  background: none; border: none;
  color: var(--text-ghost); cursor: pointer;
  font-size: 0.9rem; padding: 0.2rem 0.4rem;
  transition: color 0.15s; flex-shrink: 0;
}
.notes-panel__close:hover { color: var(--text-primary); }

/* Previous sessions scroll area */
.notes-panel__sessions {
  flex: 0 0 auto;
  max-height: 180px;
  overflow-y: auto;
  padding: 0.8rem 1.5rem;
  border-bottom: 1px solid var(--border);
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.notes-session-entry { margin-bottom: 1rem; }
.notes-session-entry__date {
  font-family: var(--font-mono); font-size: 0.52rem;
  color: var(--text-ghost); letter-spacing: 0.15em; margin-bottom: 0.3rem;
}
.notes-session-entry__text {
  font-family: var(--font-mono); font-size: 0.68rem;
  color: var(--text-muted); line-height: 1.55;
  white-space: pre-wrap; word-break: break-word;
}

/* Compose area */
.notes-panel__compose {
  flex: 1; display: flex; flex-direction: column;
  padding: 1rem 1.5rem 1.5rem; min-height: 0;
}
.notes-panel__session-label {
  font-family: var(--font-mono); font-size: 0.52rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--cinnabar); margin-bottom: 0.6rem;
}
.notes-panel__textarea {
  flex: 1; background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-secondary); font-family: var(--font-mono);
  font-size: 0.75rem; line-height: 1.65;
  padding: 0.9rem 1rem; resize: none; outline: none;
  min-height: 0; transition: border-color 0.2s;
}
.notes-panel__textarea:focus { border-color: var(--border-hi); }

.notes-panel__actions {
  display: flex; gap: 0.5rem; margin-top: 0.8rem;
}
.notes-panel__btn {
  font-family: var(--font-mono); font-size: 0.58rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.45rem 1rem; border: 1px solid var(--border);
  background: none; color: var(--text-muted); cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.notes-panel__btn--save:hover   { border-color: var(--cinnabar); color: var(--cinnabar); }
.notes-panel__btn--export:hover { border-color: var(--text-secondary); color: var(--text-secondary); }

.notes-panel__hint {
  font-family: var(--font-mono); font-size: 0.52rem;
  color: var(--text-ghost); margin-top: 0.6rem; line-height: 1.5;
}
.notes-panel__hint code {
  color: var(--text-muted); background: var(--bg-raised); padding: 0.1em 0.3em;
}

/* Trigger button */
.notes-trigger {
  position: fixed; bottom: 5.5rem; right: 1.5rem;
  display: flex; align-items: center; gap: 0.5rem;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-ghost); font-family: var(--font-mono);
  font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.5rem 0.9rem; cursor: pointer; z-index: 100;
  transition: border-color 0.2s, color 0.2s;
}
.notes-trigger:hover { border-color: var(--cinnabar); color: var(--cinnabar); }
.notes-trigger__icon { font-size: 0.85rem; line-height: 1; }

/* Backdrop */
.notes-backdrop {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.35); z-index: 499;
}
.notes-backdrop.active { display: block; }
</style>

<script define:vars={{ slug, courseTitle }}>
const STORAGE_KEY  = `sn-notes:${slug}`
const TODAY        = new Date().toISOString().slice(0, 10)

const panel      = document.getElementById('notes-panel')
const backdrop   = document.getElementById('notes-backdrop')
const trigger    = document.getElementById('notes-trigger')
const closeBtn   = document.getElementById('notes-close')
const textarea   = document.getElementById('notes-textarea')
const saveBtn    = document.getElementById('notes-save')
const exportBtn  = document.getElementById('notes-export')
const sessionsEl = document.getElementById('notes-sessions')
const labelEl    = document.getElementById('notes-session-label')

function getAllSessions() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}') }
  catch { return {} }
}
function saveSession(text) {
  const all = getAllSessions()
  all[TODAY] = text
  localStorage.setItem(STORAGE_KEY, JSON.stringify(all))
}
function renderPreviousSessions() {
  const past = Object.entries(getAllSessions())
    .filter(([d]) => d !== TODAY)
    .sort(([a], [b]) => b.localeCompare(a))
  if (past.length === 0) {
    sessionsEl.innerHTML = '<p style="font-family:var(--font-mono);font-size:0.58rem;color:var(--text-ghost);padding:0.3rem 0">No previous sessions</p>'
    return
  }
  sessionsEl.innerHTML = past.map(([date, text]) => `
    <div class="notes-session-entry">
      <div class="notes-session-entry__date">${date}</div>
      <div class="notes-session-entry__text">${text.slice(0,200)}${text.length>200?'…':''}</div>
    </div>`).join('')
}

function openPanel() {
  panel?.setAttribute('aria-hidden', 'false')
  backdrop?.classList.add('active')
  trigger?.setAttribute('aria-expanded', 'true')
  if (labelEl) labelEl.textContent = `Session — ${TODAY}`
  if (textarea) textarea.value = getAllSessions()[TODAY] ?? ''
  renderPreviousSessions()
  setTimeout(() => textarea?.focus(), 350)
}
function closePanel() {
  panel?.setAttribute('aria-hidden', 'true')
  backdrop?.classList.remove('active')
  trigger?.setAttribute('aria-expanded', 'false')
}

trigger?.addEventListener('click', openPanel)
closeBtn?.addEventListener('click', closePanel)
backdrop?.addEventListener('click', closePanel)
textarea?.addEventListener('input', () => saveSession(textarea.value))

saveBtn?.addEventListener('click', () => {
  saveSession(textarea.value)
  saveBtn.textContent = 'Saved ✓'
  setTimeout(() => { saveBtn.textContent = 'Save' }, 1500)
})

exportBtn?.addEventListener('click', () => {
  const entries = Object.entries(getAllSessions()).sort(([a],[b]) => b.localeCompare(a))
  if (!entries.length) { alert('No notes to export.'); return }
  const md = `# Course Notes — ${courseTitle}\n\n` +
    entries.map(([date, text]) => `## ${date}\n\n${text.trim()}`).join('\n\n---\n\n')
  const url = URL.createObjectURL(new Blob([md], { type: 'text/markdown' }))
  const a = Object.assign(document.createElement('a'), { href: url, download: `notes-${slug}-${TODAY}.md` })
  a.click(); URL.revokeObjectURL(url)
})

document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && panel?.getAttribute('aria-hidden') === 'false') closePanel()
})
</script>
