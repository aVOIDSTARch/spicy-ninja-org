---
/*
  ThemeToggle.astro
  Floating lantern button — switches between Woodblock (dark) and Red Lacquer (light).
  - Reads/writes data-theme on <html>
  - Persists to localStorage under key "sn-theme"
  - Defaults to "dark" if no preference stored
  - No flash on load: <Base.astro> sets data-theme inline before paint
  - Lantern SVG changes fill/glow color between themes
*/
---

<button
  class="lantern-toggle"
  id="theme-toggle"
  aria-label="Toggle theme"
  title="Toggle light / dark theme"
>
  <!-- Lantern SVG — warm paper lantern silhouette -->
  <svg viewBox="0 0 36 44" fill="none" xmlns="http://www.w3.org/2000/svg" id="lantern-svg">
    <!-- Hanging cord -->
    <line x1="18" y1="0" x2="18" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <!-- Top cap -->
    <rect x="10" y="5" width="16" height="3" rx="1.5" fill="currentColor"/>
    <!-- Main body -->
    <ellipse cx="18" cy="22" rx="12" ry="14" fill="currentColor" id="lantern-body"/>
    <!-- Inner glow (changes with theme) -->
    <ellipse cx="18" cy="22" rx="8" ry="10" fill="var(--sil-window)" opacity="0.55" id="lantern-glow"/>
    <!-- Ribs -->
    <line x1="8" y1="16" x2="28" y2="16" stroke="var(--bg-secondary)" stroke-width="0.8" opacity="0.5"/>
    <line x1="7" y1="22" x2="29" y2="22" stroke="var(--bg-secondary)" stroke-width="0.8" opacity="0.5"/>
    <line x1="8" y1="28" x2="28" y2="28" stroke="var(--bg-secondary)" stroke-width="0.8" opacity="0.5"/>
    <!-- Bottom cap -->
    <rect x="10" y="34" width="16" height="3" rx="1.5" fill="currentColor"/>
    <!-- Tassel -->
    <line x1="16" y1="37" x2="16" y2="43" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
    <line x1="18" y1="37" x2="18" y2="44" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
    <line x1="20" y1="37" x2="20" y2="43" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
  </svg>
</button>

<script>
  const STORAGE_KEY = 'sn-theme'
  const DEFAULT_THEME = 'dark'

  function getTheme(): string {
    return localStorage.getItem(STORAGE_KEY) ?? DEFAULT_THEME
  }

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme)
    localStorage.setItem(STORAGE_KEY, theme)
  }

  function toggleTheme() {
    const current = getTheme()
    applyTheme(current === 'dark' ? 'light' : 'dark')
  }

  // Apply on mount (handles navigation to new pages)
  applyTheme(getTheme())

  // Wire the button
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme)
</script>
